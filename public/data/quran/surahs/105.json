    {
      "number": 105,
      "name": "سُورَةُ الفِيلِ",
      "englishName": "Al-Fil",
      "englishNameTranslation": "The Elephant",
      "revelationType": "Meccan",
      "numberOfAyahs": 5,
      "ayahs": [
        {
          "number": 6189,
          "text": "আপনি কি দেখেননি আপনার পালনকর্তা হস্তীবাহিনীর সাথে কিরূপ ব্যবহার করেছেন?",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 547,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6190,
          "text": "তিনি কি তাদের চক্রান্ত নস্যাৎ করে দেননি?",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 547,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6191,
          "text": "তিনি তাদের উপর প্রেরণ করেছেন ঝাঁকে ঝাঁকে পাখী,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 547,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6192,
          "text": "যারা তাদের উপর পাথরের কংকর নিক্ষেপ করছিল।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 547,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6193,
          "text": "অতঃপর তিনি তাদেরকে ভক্ষিত তৃণসদৃশ করে দেন।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 547,
          "hizbQuarter": 240,
          "sajda": false
        }
      ],
