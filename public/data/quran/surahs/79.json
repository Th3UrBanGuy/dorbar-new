    {
      "number": 79,
      "name": "سُورَةُ النَّازِعَاتِ",
      "englishName": "An-Naazi'aat",
      "englishNameTranslation": "Those who drag forth",
      "revelationType": "Meccan",
      "numberOfAyahs": 46,
      "ayahs": [
        {
          "number": 5713,
          "text": "শপথ সেই ফেরেশতাগণের, যারা ডুব দিয়ে আত্মা উৎপাটন করে,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5714,
          "text": "শপথ তাদের, যারা আত্মার বাঁধন খুলে দেয় মৃদুভাবে;",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5715,
          "text": "শপথ তাদের, যারা সন্তরণ করে দ্রুতগতিতে,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5716,
          "text": "শপথ তাদের, যারা দ্রুতগতিতে অগ্রসর হয় এবং",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5717,
          "text": "শপথ তাদের, যারা সকল কর্মনির্বাহ করে, কেয়ামত অবশ্যই হবে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5718,
          "text": "যেদিন প্রকম্পিত করবে প্রকম্পিতকারী,",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5719,
          "text": "অতঃপর পশ্চাতে আসবে পশ্চাদগামী;",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5720,
          "text": "সেদিন অনেক হৃদয় ভীত-বিহবল হবে।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5721,
          "text": "তাদের দৃষ্টি নত হবে।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5722,
          "text": "তারা বলেঃ আমরা কি উলটো পায়ে প্রত্যাবর্তিত হবই-",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5723,
          "text": "গলিত অস্থি হয়ে যাওয়ার পরও?",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5724,
          "text": "তবে তো এ প্রত্যাবর্তন সর্বনাশা হবে!",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5725,
          "text": "অতএব, এটা তো কেবল এক মহা-নাদ,",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5726,
          "text": "তখনই তারা ময়দানে আবির্ভূত হবে।",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5727,
          "text": "মূসার বৃত্তান্ত আপনার কাছে পৌছেছে কি?",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5728,
          "text": "যখন তার পালনকর্তা তাকে পবিত্র তুয়া উপ্যকায় আহবান করেছিলেন,",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5729,
          "text": "ফেরাউনের কাছে যাও, নিশ্চয় সে সীমালংঘন করেছে।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5730,
          "text": "অতঃপর বলঃ তোমার পবিত্র হওয়ার আগ্রহ আছে কি?",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5731,
          "text": "আমি তোমাকে তোমার পালনকর্তার দিকে পথ দেখাব, যাতে তুমি তাকে ভয় কর।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5732,
          "text": "অতঃপর সে তাকে মহা-নিদর্শন দেখাল।",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5733,
          "text": "কিন্তু সে মিথ্যারোপ করল এবং অমান্য করল।",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5734,
          "text": "অতঃপর সে প্রতিকার চেষ্টায় প্রস্থান করল।",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5735,
          "text": "সে সকলকে সমবেত করল এবং সজোরে আহবান করল,",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5736,
          "text": "এবং বললঃ আমিই তোমাদের সেরা পালনকর্তা।",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5737,
          "text": "অতঃপর আল্লাহ তাকে পরকালের ও ইহকালের শাস্তি দিলেন।",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5738,
          "text": "যে ভয় করে তার জন্যে অবশ্যই এতে শিক্ষা রয়েছে।",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 520,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5739,
          "text": "তোমাদের সৃষ্টি অধিক কঠিন না আকাশের, যা তিনি নির্মাণ করেছেন?",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5740,
          "text": "তিনি একে উচ্চ করেছেন ও সুবিন্যস্ত করেছেন।",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5741,
          "text": "তিনি এর রাত্রিকে করেছেন অন্ধকারাচ্ছন্ন এবং এর সূর্যোলোক প্রকাশ করেছেন।",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5742,
          "text": "পৃথিবীকে এর পরে বিস্তৃত করেছেন।",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5743,
          "text": "তিনি এর মধ্য থেকে এর পানি ও ঘাম নির্গত করেছেন,",
          "numberInSurah": 31,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5744,
          "text": "পর্বতকে তিনি দৃঢ়ভাবে প্রতিষ্ঠিত করেছেন,",
          "numberInSurah": 32,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5745,
          "text": "তোমাদের ও তোমাদের চতুস্পদ জন্তুদের উপকারার্থে।",
          "numberInSurah": 33,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5746,
          "text": "অতঃপর যখন মহাসংকট এসে যাবে।",
          "numberInSurah": 34,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5747,
          "text": "অর্থাৎ যেদিন মানুষ তার কৃতকর্ম স্মরণ করবে",
          "numberInSurah": 35,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5748,
          "text": "এবং দর্শকদের জন্যে জাহান্নাম প্রকাশ করা হবে,",
          "numberInSurah": 36,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5749,
          "text": "তখন যে ব্যক্তি সীমালংঘন করেছে;",
          "numberInSurah": 37,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5750,
          "text": "এবং পার্থিব জীবনকে অগ্রাধিকার দিয়েছে,",
          "numberInSurah": 38,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5751,
          "text": "তার ঠিকানা হবে জাহান্নাম।",
          "numberInSurah": 39,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5752,
          "text": "পক্ষান্তরে যে ব্যক্তি তার পালনকর্তার সামনে দন্ডায়মান হওয়াকে ভয় করেছে এবং খেয়াল-খুশী থেকে নিজেকে নিবৃত্ত রেখেছে,",
          "numberInSurah": 40,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5753,
          "text": "তার ঠিকানা হবে জান্নাত।",
          "numberInSurah": 41,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5754,
          "text": "তারা আপনাকে জিজ্ঞাসা করে, কেয়ামত কখন হবে?",
          "numberInSurah": 42,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5755,
          "text": "এর বর্ণনার সাথে আপনার কি সম্পর্ক ?",
          "numberInSurah": 43,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5756,
          "text": "এর চরম জ্ঞান আপনার পালনকর্তার কাছে।",
          "numberInSurah": 44,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5757,
          "text": "যে একে ভয় করে, আপনি তো কেবল তাকেই সতর্ক করবেন।",
          "numberInSurah": 45,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5758,
          "text": "যেদিন তারা একে দেখবে, সেদিন মনে হবে যেন তারা দুনিয়াতে মাত্র এক সন্ধ্যা অথবা এক সকাল অবস্থান করেছে।",
          "numberInSurah": 46,
          "juz": 30,
          "manzil": 7,
          "page": 584,
          "ruku": 521,
          "hizbQuarter": 233,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}