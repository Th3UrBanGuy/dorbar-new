          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6206,
          "text": "অতএব আপনার পালনকর্তার উদ্দেশ্যে নামায পড়ুন এবং কোরবানী করুন।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 602,
          "ruku": 550,
          "hizbQuarter": 240,
          "sajda": false
        },
