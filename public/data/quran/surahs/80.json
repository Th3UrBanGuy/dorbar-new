  "data": [
    {
      "number": 80,
      "name": "سُورَةُ عَبَسَ",
      "englishName": "Abasa",
      "englishNameTranslation": "He frowned",
      "revelationType": "Meccan",
      "numberOfAyahs": 42,
      "ayahs": [
        {
          "number": 5759,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ عَبَسَ وَتَوَلَّىٰٓ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5760,
          "text": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5761,
          "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5762,
          "text": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5763,
          "text": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5764,
          "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5765,
          "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5766,
          "text": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5767,
          "text": "وَهُوَ يَخْشَىٰ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5768,
          "text": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5769,
          "text": "كَلَّآ إِنَّهَا تَذْكِرَةٌۭ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5770,
          "text": "فَمَن شَآءَ ذَكَرَهُۥ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5771,
          "text": "فِى صُحُفٍۢ مُّكَرَّمَةٍۢ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5772,
          "text": "مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5773,
          "text": "بِأَيْدِى سَفَرَةٍۢ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5774,
          "text": "كِرَامٍۭ بَرَرَةٍۢ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5775,
          "text": "قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5776,
          "text": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5777,
          "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5778,
          "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5779,
          "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5780,
          "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5781,
          "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5782,
          "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5783,
          "text": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5784,
          "text": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5785,
          "text": "فَأَنۢبَتْنَا فِيهَا حَبًّۭا",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5786,
          "text": "وَعِنَبًۭا وَقَضْبًۭا",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5787,
          "text": "وَزَيْتُونًۭا وَنَخْلًۭا",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5788,
          "text": "وَحَدَآئِقَ غُلْبًۭا",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5789,
          "text": "وَفَٰكِهَةًۭ وَأَبًّۭا",
          "numberInSurah": 31,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5790,
          "text": "مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
          "numberInSurah": 32,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5791,
          "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
          "numberInSurah": 33,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5792,
          "text": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
          "numberInSurah": 34,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5793,
          "text": "وَأُمِّهِۦ وَأَبِيهِ",
          "numberInSurah": 35,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5794,
          "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ",
          "numberInSurah": 36,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5795,
          "text": "لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ",
          "numberInSurah": 37,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5796,
          "text": "وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ",
          "numberInSurah": 38,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5797,
          "text": "ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ",
          "numberInSurah": 39,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5798,
          "text": "وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ",
          "numberInSurah": 40,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5799,
          "text": "تَرْهَقُهَا قَتَرَةٌ",
          "numberInSurah": 41,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5800,
          "text": "أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
          "numberInSurah": 42,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 80,
      "name": "سُورَةُ عَبَسَ",
      "englishName": "Abasa",
      "englishNameTranslation": "He frowned",
      "revelationType": "Meccan",
      "numberOfAyahs": 42,
      "ayahs": [
        {
          "number": 5759,
          "text": "তিনি ভ্রূকুঞ্চিত করলেন এবং মুখ ফিরিয়ে নিলেন।",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5760,
          "text": "কারণ, তাঁর কাছে এক অন্ধ আগমন করল।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5761,
          "text": "আপনি কি জানেন, সে হয়তো পরিশুদ্ধ হত,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5762,
          "text": "অথবা উপদেশ গ্রহণ করতো এবং উপদেশ তার উপকার হত।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5763,
          "text": "পরন্তু যে বেপরোয়া,",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5764,
          "text": "আপনি তার চিন্তায় মশগুল।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5765,
          "text": "সে শুদ্ধ না হলে আপনার কোন দোষ নেই।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5766,
          "text": "যে আপনার কাছে দৌড়ে আসলো",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5767,
          "text": "এমতাবস্থায় যে, সে ভয় করে,",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5768,
          "text": "আপনি তাকে অবজ্ঞা করলেন।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5769,
          "text": "কখনও এরূপ করবেন না, এটা উপদেশবানী।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5770,
          "text": "অতএব, যে ইচ্ছা করবে, সে একে গ্রহণ করবে।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5771,
          "text": "এটা লিখিত আছে সম্মানিত,",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5772,
          "text": "উচ্চ পবিত্র পত্রসমূহে,",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5773,
          "text": "লিপিকারের হস্তে,",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5774,
          "text": "যারা মহৎ, পূত চরিত্র।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5775,
          "text": "মানুষ ধ্বংস হোক, সে কত অকৃতজ্ঞ!",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5776,
          "text": "তিনি তাকে কি বস্তু থেকে সৃষ্টি করেছেন?",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5777,
          "text": "শুক্র থেকে তাকে সৃষ্টি করেছেন, অতঃপর তাকে সুপরিমিত করেছেন।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5778,
          "text": "অতঃপর তার পথ সহজ করেছেন,",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5779,
          "text": "অতঃপর তার মৃত্যু ঘটান ও কবরস্থ করেন তাকে।",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5780,
          "text": "এরপর যখন ইচ্ছা করবেন তখন তাকে পুনরুজ্জীবিত করবেন।",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5781,
          "text": "সে কখনও কৃতজ্ঞ হয়নি, তিনি তাকে যা আদেশ করেছেন, সে তা পূর্ণ করেনি।",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5782,
          "text": "মানুষ তার খাদ্যের প্রতি লক্ষ্য করুক,",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5783,
          "text": "আমি আশ্চর্য উপায়ে পানি বর্ষণ করেছি,",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5784,
          "text": "এরপর আমি ভূমিকে বিদীর্ণ করেছি,",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5785,
          "text": "অতঃপর তাতে উৎপন্ন করেছি শস্য,",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5786,
          "text": "আঙ্গুর, শাক-সব্জি,",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5787,
          "text": "যয়তুন, খর্জূর,",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5788,
          "text": "ঘন উদ্যান,",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5789,
          "text": "ফল এবং ঘাস",
          "numberInSurah": 31,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5790,
          "text": "তোমাদেরও তোমাদের চতুস্পদ জন্তুদের উপাকারার্থে।",
          "numberInSurah": 32,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5791,
          "text": "অতঃপর যেদিন কর্ণবিদারক নাদ আসবে,",
          "numberInSurah": 33,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5792,
          "text": "সেদিন পলায়ন করবে মানুষ তার ভ্রাতার কাছ থেকে,",
          "numberInSurah": 34,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5793,
          "text": "তার মাতা, তার পিতা,",
          "numberInSurah": 35,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5794,
          "text": "তার পত্নী ও তার সন্তানদের কাছ থেকে।",
          "numberInSurah": 36,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5795,
          "text": "সেদিন প্রত্যেকেরই নিজের এক চিন্তা থাকবে, যা তাকে ব্যতিব্যস্ত করে রাখবে।",
          "numberInSurah": 37,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5796,
          "text": "অনেক মুখমন্ডল সেদিন হবে উজ্জ্বল,",
          "numberInSurah": 38,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5797,
          "text": "সহাস্য ও প্রফুল্ল।",
          "numberInSurah": 39,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5798,
          "text": "এবং অনেক মুখমন্ডল সেদিন হবে ধুলি ধূসরিত।",
          "numberInSurah": 40,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5799,
          "text": "তাদেরকে কালিমা আচ্ছন্ন করে রাখবে।",
          "numberInSurah": 41,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        },
        {
          "number": 5800,
          "text": "তারাই কাফের পাপিষ্ঠের দল।",
          "numberInSurah": 42,
          "juz": 30,
          "manzil": 7,
          "page": 585,
          "ruku": 522,
          "hizbQuarter": 234,
          "sajda": false
        }
      ],
