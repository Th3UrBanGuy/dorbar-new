      }
    },
    {
      "number": 78,
      "name": "سُورَةُ النَّبَإِ",
      "englishName": "An-Naba",
      "englishNameTranslation": "The Announcement",
      "revelationType": "Meccan",
      "numberOfAyahs": 40,
      "ayahs": [
        {
          "number": 5673,
          "text": "তারা পরস্পরে কি বিষয়ে জিজ্ঞাসাবাদ করছে?",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5674,
          "text": "মহা সংবাদ সম্পর্কে,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5675,
          "text": "যে সম্পর্কে তারা মতানৈক্য করে।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5676,
          "text": "না, সত্ত্বরই তারা জানতে পারবে,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5677,
          "text": "অতঃপর না, সত্বর তারা জানতে পারবে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5678,
          "text": "আমি কি করিনি ভূমিকে বিছানা",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5679,
          "text": "এবং পর্বতমালাকে পেরেক?",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5680,
          "text": "আমি তোমাদেরকে জোড়া জোড়া সৃষ্টি করেছি,",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5681,
          "text": "তোমাদের নিদ্রাকে করেছি ক্লান্তি দূরকারী,",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5682,
          "text": "রাত্রিকে করেছি আবরণ।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5683,
          "text": "দিনকে করেছি জীবিকা অর্জনের সময়,",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5684,
          "text": "নির্মান করেছি তোমাদের মাথার উপর মজবুত সপ্ত-আকাশ।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5685,
          "text": "এবং একটি উজ্জ্বল প্রদীপ সৃষ্টি করেছি।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5686,
          "text": "আমি জলধর মেঘমালা থেকে প্রচুর বৃষ্টিপাত করি,",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5687,
          "text": "যাতে তদ্দ্বারা উৎপন্ন করি শস্য, উদ্ভিদ।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5688,
          "text": "ও পাতাঘন উদ্যান।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5689,
          "text": "নিশ্চয় বিচার দিবস নির্ধারিত রয়েছে।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5690,
          "text": "যেদিন শিংগায় ফুঁক দেয়া হবে, তখন তোমরা দলে দলে সমাগত হবে।",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5691,
          "text": "আকাশ বিদীর্ণ হয়ে; তাতে বহু দরজা সৃষ্টি হবে।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5692,
          "text": "এবং পর্বতমালা চালিত হয়ে মরীচিকা হয়ে যাবে।",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5693,
          "text": "নিশ্চয় জাহান্নাম প্রতীক্ষায় থাকবে,",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5694,
          "text": "সীমালংঘনকারীদের আশ্রয়স্থলরূপে।",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5695,
          "text": "তারা তথায় শতাব্দীর পর শতাব্দী অবস্থান করবে।",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5696,
          "text": "তথায় তারা কোন শীতল এবং পানীয় আস্বাদন করবে না;",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5697,
          "text": "কিন্তু ফুটন্ত পানি ও পূঁজ পাবে।",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5698,
          "text": "পরিপূর্ণ প্রতিফল হিসেবে।",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5699,
          "text": "নিশ্চয় তারা হিসাব-নিকাশ আশা করত না।",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5700,
          "text": "এবং আমার আয়াতসমূহে পুরোপুরি মিথ্যারোপ করত।",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5701,
          "text": "আমি সবকিছুই লিপিবদ্ধ করে সংরক্ষিত করেছি।",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5702,
          "text": "অতএব, তোমরা আস্বাদন কর, আমি কেবল তোমাদের শাস্তিই বৃদ্ধি করব।",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 582,
          "ruku": 518,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5703,
          "text": "পরহেযগারদের জন্যে রয়েছে সাফল্য।",
          "numberInSurah": 31,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5704,
          "text": "উদ্যান, আঙ্গুর,",
          "numberInSurah": 32,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5705,
          "text": "সমবয়স্কা, পূর্ণযৌবনা তরুণী।",
          "numberInSurah": 33,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5706,
          "text": "এবং পূর্ণ পানপাত্র।",
          "numberInSurah": 34,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5707,
          "text": "তারা তথায় অসার ও মিথ্যা বাক্য শুনবে না।",
          "numberInSurah": 35,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5708,
          "text": "এটা আপনার পালনকর্তার তরফ থেকে যথোচিত দান,",
          "numberInSurah": 36,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5709,
          "text": "যিনি নভোমন্ডল, ভূমন্ডল ও এতদুভয়ের মধ্যবর্তী সবকিছুর পালনকর্তা, দয়াময়, কেউ তাঁর সাথে কথার অধিকারী হবে না।",
          "numberInSurah": 37,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5710,
          "text": "যেদিন রূহ ও ফেরেশতাগণ সারিবদ্ধভাবে দাঁড়াবে। দয়াময় আল্লাহ যাকে অনুমতি দিবেন, সে ব্যতিত কেউ কথা বলতে পারবে না এবং সে সত্যকথা বলবে।",
          "numberInSurah": 38,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5711,
          "text": "এই দিবস সত্য। অতঃপর যার ইচ্ছা, সে তার পালনকর্তার কাছে ঠিকানা তৈরী করুক।",
          "numberInSurah": 39,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        },
        {
          "number": 5712,
          "text": "আমি তোমাদেরকে আসন্ন শাস্তি সম্পর্কে সতর্ক করলাম, যেদিন মানুষ প্রত্যেক্ষ করবে যা সে সামনে প্রেরণ করেছে এবং কাফের বলবেঃ হায়, আফসোস-আমি যদি মাটি হয়ে যেতাম।",
          "numberInSurah": 40,
          "juz": 30,
          "manzil": 7,
          "page": 583,
          "ruku": 519,
          "hizbQuarter": 233,
          "sajda": false
        }
      ],
      "edition": {
