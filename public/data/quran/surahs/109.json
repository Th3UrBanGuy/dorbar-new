      "numberOfAyahs": 6,
      "ayahs": [
        {
          "number": 6208,
          "text": "বলুন, হে কাফেরকূল,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 551,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6209,
          "text": "আমি এবাদত করিনা, তোমরা যার এবাদত কর।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 551,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6210,
          "text": "এবং তোমরাও এবাদতকারী নও, যার এবাদত আমি করি",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 551,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6211,
          "text": "এবং আমি এবাদতকারী নই, যার এবাদত তোমরা কর।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 551,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6212,
          "text": "তোমরা এবাদতকারী নও, যার এবাদত আমি করি।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 551,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6213,
          "text": "তোমাদের কর্ম ও কর্মফল তোমাদের জন্যে এবং আমার কর্ম ও কর্মফল আমার জন্যে।",
