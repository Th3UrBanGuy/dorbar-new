  "data": [
    {
      "number": 82,
      "name": "سُورَةُ الانفِطَارِ",
      "englishName": "Al-Infitaar",
      "englishNameTranslation": "The Cleaving",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 5830,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5831,
          "text": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5832,
          "text": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5833,
          "text": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5834,
          "text": "عَلِمَتْ نَفْسٌۭ مَّا قَدَّمَتْ وَأَخَّرَتْ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5835,
          "text": "يَٰٓأَيُّهَا ٱلْإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5836,
          "text": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5837,
          "text": "فِىٓ أَىِّ صُورَةٍۢ مَّا شَآءَ رَكَّبَكَ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5838,
          "text": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5839,
          "text": "وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5840,
          "text": "كِرَامًۭا كَٰتِبِينَ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5841,
          "text": "يَعْلَمُونَ مَا تَفْعَلُونَ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5842,
          "text": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍۢ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5843,
          "text": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍۢ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5844,
          "text": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5845,
          "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5846,
          "text": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5847,
          "text": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5848,
          "text": "يَوْمَ لَا تَمْلِكُ نَفْسٌۭ لِّنَفْسٍۢ شَيْـًۭٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍۢ لِّلَّهِ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 82,
      "name": "سُورَةُ الانفِطَارِ",
      "englishName": "Al-Infitaar",
      "englishNameTranslation": "The Cleaving",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 5830,
          "text": "যখন আকাশ বিদীর্ণ হবে,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5831,
          "text": "যখন নক্ষত্রসমূহ ঝরে পড়বে,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5832,
          "text": "যখন সমুদ্রকে উত্তাল করে তোলা হবে,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5833,
          "text": "এবং যখন কবরসমূহ উম্মোচিত হবে,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5834,
          "text": "তখন প্রত্যেকে জেনে নিবে সে কি অগ্রে প্রেরণ করেছে এবং কি পশ্চাতে ছেড়ে এসেছে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5835,
          "text": "হে মানুষ, কিসে তোমাকে তোমার মহামহিম পালনকর্তা সম্পর্কে বিভ্রান্ত করল?",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5836,
          "text": "যিনি তোমাকে সৃষ্টি করেছেন, অতঃপর তোমাকে সুবিন্যস্ত করেছেন এবং সুষম করেছেন।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5837,
          "text": "যিনি তোমাকে তাঁর ইচ্ছামত আকৃতিতে গঠন করেছেন।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5838,
          "text": "কখনও বিভ্রান্ত হয়ো না; বরং তোমরা দান-প্রতিদানকে মিথ্যা মনে কর।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5839,
          "text": "অবশ্যই তোমাদের উপর তত্ত্বাবধায়ক নিযুক্ত আছে।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5840,
          "text": "সম্মানিত আমল লেখকবৃন্দ।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5841,
          "text": "তারা জানে যা তোমরা কর।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5842,
          "text": "সৎকর্মশীলগণ থাকবে জান্নাতে।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5843,
          "text": "এবং দুষ্কর্মীরা থাকবে জাহান্নামে;",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5844,
          "text": "তারা বিচার দিবসে তথায় প্রবেশ করবে।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5845,
          "text": "তারা সেখান থেকে পৃথক হবে না।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5846,
          "text": "আপনি জানেন, বিচার দিবস কি?",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5847,
          "text": "অতঃপর আপনি জানেন, বিচার দিবস কি?",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        },
        {
          "number": 5848,
          "text": "যেদিন কেউ কারও কোন উপকার করতে পারবে না এবং সেদিন সব কতৃꦣ2468;্ব হবে আল্লাহর।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 587,
          "ruku": 524,
          "hizbQuarter": 235,
          "sajda": false
        }
      ],
      "edition": {
