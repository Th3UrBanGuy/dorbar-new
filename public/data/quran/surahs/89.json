  "data": [
    {
      "number": 89,
      "name": "سُورَةُ الفَجۡرِ",
      "englishName": "Al-Fajr",
      "englishNameTranslation": "The Dawn",
      "revelationType": "Meccan",
      "numberOfAyahs": 30,
      "ayahs": [
        {
          "number": 5994,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْفَجْرِ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5995,
          "text": "وَلَيَالٍ عَشْرٍۢ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5996,
          "text": "وَٱلشَّفْعِ وَٱلْوَتْرِ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5997,
          "text": "وَٱلَّيْلِ إِذَا يَسْرِ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5998,
          "text": "هَلْ فِى ذَٰلِكَ قَسَمٌۭ لِّذِى حِجْرٍ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5999,
          "text": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6000,
          "text": "إِرَمَ ذَاتِ ٱلْعِمَادِ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6001,
          "text": "ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَٰدِ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6002,
          "text": "وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6003,
          "text": "وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6004,
          "text": "ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَٰدِ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6005,
          "text": "فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6006,
          "text": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6007,
          "text": "إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6008,
          "text": "فَأَمَّا ٱلْإِنسَٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6009,
          "text": "وَأَمَّآ إِذَا مَا ٱبْتَلَىٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ فَيَقُولُ رَبِّىٓ أَهَٰنَنِ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6010,
          "text": "كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6011,
          "text": "وَلَا تَحَٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6012,
          "text": "وَتَأْكُلُونَ ٱلتُّرَاثَ أَكْلًۭا لَّمًّۭا",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6013,
          "text": "وَتُحِبُّونَ ٱلْمَالَ حُبًّۭا جَمًّۭا",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6014,
          "text": "كَلَّآ إِذَا دُكَّتِ ٱلْأَرْضُ دَكًّۭا دَكًّۭا",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6015,
          "text": "وَجَآءَ رَبُّكَ وَٱلْمَلَكُ صَفًّۭا صَفًّۭا",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6016,
          "text": "وَجِا۟ىٓءَ يَوْمَئِذٍۭ بِجَهَنَّمَ ۚ يَوْمَئِذٍۢ يَتَذَكَّرُ ٱلْإِنسَٰنُ وَأَنَّىٰ لَهُ ٱلذِّكْرَىٰ",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6017,
          "text": "يَقُولُ يَٰلَيْتَنِى قَدَّمْتُ لِحَيَاتِى",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6018,
          "text": "فَيَوْمَئِذٍۢ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٌۭ",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6019,
          "text": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٌۭ",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6020,
          "text": "يَٰٓأَيَّتُهَا ٱلنَّفْسُ ٱلْمُطْمَئِنَّةُ",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6021,
          "text": "ٱرْجِعِىٓ إِلَىٰ رَبِّكِ رَاضِيَةًۭ مَّرْضِيَّةًۭ",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6022,
          "text": "فَٱدْخُلِى فِى عِبَٰدِى",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6023,
          "text": "وَٱدْخُلِى جَنَّتِى",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 89,
      "name": "سُورَةُ الفَجۡرِ",
      "englishName": "Al-Fajr",
      "englishNameTranslation": "The Dawn",
      "revelationType": "Meccan",
      "numberOfAyahs": 30,
      "ayahs": [
        {
          "number": 5994,
          "text": "শপথ ফজরের,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5995,
          "text": "শপথ দশ রাত্রির, শপথ তার,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5996,
          "text": "যা জোড় ও যা বিজোড়",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5997,
          "text": "এবং শপথ রাত্রির যখন তা গত হতে থাকে",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5998,
          "text": "এর মধ্যে আছে শপথ জ্ঞানী ব্যক্তির জন্যে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5999,
          "text": "আপনি কি লক্ষ্য করেননি, আপনার পালনকর্তা আদ বংশের ইরাম গোত্রের সাথে কি আচরণ করেছিলেন,",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6000,
          "text": "যাদের দৈহিক গঠন স্তম্ভ ও খুঁটির ন্যায় দীর্ঘ ছিল এবং",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6001,
          "text": "যাদের সমান শক্তি ও বলবীর্যে সারা বিশ্বের শহরসমূহে কোন লোক সৃজিত হয়নি",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6002,
          "text": "এবং সামুদ গোত্রের সাথে, যারা উপত্যকায় পাথর কেটে গৃহ নির্মাণ করেছিল।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6003,
          "text": "এবং বহু কীলকের অধিপতি ফেরাউনের সাথে",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6004,
          "text": "যারা দেশে সীমালঙ্ঘন করেছিল।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6005,
          "text": "অতঃপর সেখানে বিস্তর অশান্তি সৃষ্টি করেছিল।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6006,
          "text": "অতঃপর আপনার পালনকর্তা তাদেরকে শাস্তির কশাঘাত করলেন।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6007,
          "text": "নিশ্চয় আপনার পালকর্তা সতর্ক দৃষ্টি রাখেন।",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6008,
          "text": "মানুষ এরূপ যে, যখন তার পালনকর্তা তাকে পরীক্ষা করেন, অতঃপর সম্মান ও অনুগ্রহ দান করেন, তখন বলে, আমার পালনকর্তা আমাকে সম্মান দান করেছেন।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6009,
          "text": "এবং যখন তাকে পরীক্ষা করেন, অতঃপর রিযিক সংকুচিত করে দেন, তখন বলেঃ আমার পালনকর্তা আমাকে হেয় করেছেন।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6010,
          "text": "এটা অমূলক, বরং তোমরা এতীমকে সম্মান কর না।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6011,
          "text": "এবং মিসকীনকে অন্নদানে পরস্পরকে উৎসাহিত কর না।",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6012,
          "text": "এবং তোমরা মৃতের ত্যাজ্য সম্পত্তি সম্পূর্ণরূপে কুক্ষিগত করে ফেল",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6013,
          "text": "এবং তোমরা ধন-সম্পদকে প্রাণভরে ভালবাস।",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6014,
          "text": "এটা অনুচিত। যখন পৃথিবী চুর্ণ-বিচুর্ণ হবে",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6015,
          "text": "এবং আপনার পালনকর্তা ও ফেরেশতাগণ সারিবদ্ধভাবে উপস্থিত হবেন,",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6016,
          "text": "এবং সেদিন জাহান্নামকে আনা হবে, সেদিন মানুষ স্মরণ করবে, কিন্তু এই স্মরণ তার কি কাজে আসবে?",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 593,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6017,
          "text": "সে বলবেঃ হায়, এ জীবনের জন্যে আমি যদি কিছু অগ্রে প্রেরণ করতাম!",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6018,
          "text": "সেদিন তার শাস্তির মত শাস্তি কেউ দিবে না।",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6019,
          "text": "এবং তার বন্ধনের মত বন্ধন কেউ দিবে না।",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6020,
          "text": "হে প্রশান্ত মন,",
          "numberInSurah": 27,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6021,
          "text": "তুমি তোমার পালনকর্তার নিকট ফিরে যাও সন্তুষ্ট ও সন্তোষভাজন হয়ে।",
          "numberInSurah": 28,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6022,
          "text": "অতঃপর আমার বান্দাদের অন্তর্ভুক্ত হয়ে যাও।",
          "numberInSurah": 29,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 6023,
          "text": "এবং আমার জান্নাতে প্রবেশ কর।",
          "numberInSurah": 30,
          "juz": 30,
          "manzil": 7,
          "page": 594,
          "ruku": 531,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
