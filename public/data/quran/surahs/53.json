        "direction": "rtl"
      }
    },
    {
      "number": 53,
      "name": "سُورَةُ النَّجۡمِ",
      "englishName": "An-Najm",
      "englishNameTranslation": "The Star",
      "revelationType": "Meccan",
      "numberOfAyahs": 62,
      "ayahs": [
        {
          "number": 4785,
          "text": "নক্ষত্রের কসম, যখন অস্তমিত হয়।",
          "numberInSurah": 1,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4786,
          "text": "তোমাদের সংগী পথভ্রষ্ট হননি এবং বিপথগামীও হননি।",
          "numberInSurah": 2,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4787,
          "text": "এবং প্রবৃত্তির তাড়নায় কথা বলেন না।",
          "numberInSurah": 3,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4788,
          "text": "কোরআন ওহী, যা প্রত্যাদেশ হয়।",
          "numberInSurah": 4,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4789,
          "text": "তাঁকে শিক্ষা দান করে এক শক্তিশালী ফেরেশতা,",
          "numberInSurah": 5,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4790,
          "text": "সহজাত শক্তিসম্পন্ন, সে নিজ আকৃতিতে প্রকাশ পেল।",
          "numberInSurah": 6,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4791,
          "text": "উর্ধ্ব দিগন্তে,",
          "numberInSurah": 7,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4792,
          "text": "অতঃপর নিকটবর্তী হল ও ঝুলে গেল।",
          "numberInSurah": 8,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4793,
          "text": "তখন দুই ধনুকের ব্যবধান ছিল অথবা আরও কম।",
          "numberInSurah": 9,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4794,
          "text": "তখন আল্লাহ তাঁর দাসের প্রতি যা প্রত্যাদেশ করবার, তা প্রত্যাদেশ করলেন।",
          "numberInSurah": 10,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4795,
          "text": "রসূলের অন্তর মিথ্যা বলেনি যা সে দেখেছে।",
          "numberInSurah": 11,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4796,
          "text": "তোমরা কি বিষয়ে বিতর্ক করবে যা সে দেখেছে?",
          "numberInSurah": 12,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4797,
          "text": "নিশ্চয় সে তাকে আরেকবার দেখেছিল,",
          "numberInSurah": 13,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4798,
          "text": "সিদরাতুলমুন্তাহার নিকটে,",
          "numberInSurah": 14,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4799,
          "text": "যার কাছে অবস্থিত বসবাসের জান্নাত।",
          "numberInSurah": 15,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4800,
          "text": "যখন বৃক্ষটি দ্বারা আচ্ছন্ন হওয়ার, তদ্দ্বারা আচ্ছন্ন ছিল।",
          "numberInSurah": 16,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4801,
          "text": "তাঁর দৃষ্টিবিভ্রম হয় নি এবং সীমালংঘনও করেনি।",
          "numberInSurah": 17,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4802,
          "text": "নিশ্চয় সে তার পালনকর্তার মহান নিদর্শনাবলী অবলোকন করেছে।",
          "numberInSurah": 18,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4803,
          "text": "তোমরা কি ভেবে দেখেছ লাত ও ওযযা সম্পর্কে।",
          "numberInSurah": 19,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4804,
          "text": "এবং তৃতীয় আরেকটি মানাত সম্পর্কে?",
          "numberInSurah": 20,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4805,
          "text": "পুত্র-সন্তান কি তোমাদের জন্যে এবং কন্যা-সন্তান আল্লাহর জন্য?",
          "numberInSurah": 21,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4806,
          "text": "এমতাবস্থায় এটা তো হবে খুবই অসংগত বন্টন।",
          "numberInSurah": 22,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4807,
          "text": "এগুলো কতগুলো নাম বৈ নয়, যা তোমরা এবং তোমাদের পূর্ব-পুরুষদের রেখেছ। এর সমর্থনে আল্লাহ কোন দলীল নাযিল করেননি। তারা অনুমান এবং প্রবৃত্তিরই অনুসরণ করে। অথচ তাদের কাছে তাদের পালনকর্তার পক্ষ থেকে পথ নির্দেশ এসেছে।",
          "numberInSurah": 23,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4808,
          "text": "মানুষ যা চায়, তাই কি পায়?",
          "numberInSurah": 24,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4809,
          "text": "অতএব, পরবর্তী ও পূর্ববর্তী সব মঙ্গলই আল্লাহর হাতে।",
          "numberInSurah": 25,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 460,
          "hizbQuarter": 210,
          "sajda": false
        },
        {
          "number": 4810,
          "text": "আকাশে অনেক ফেরেশতা রয়েছে। তাদের কোন সুপারিশ ফলপ্রসূ হয় না যতক্ষণ আল্লাহ যার জন্যে ইচ্ছা ও যাকে পছন্দ করেন, অনুমতি না দেন।",
          "numberInSurah": 26,
          "juz": 27,
          "manzil": 7,
          "page": 526,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4811,
          "text": "যারা পরকালে বিশ্বাস করে না, তারাই ফেরেশতাকে নারীবাচক নাম দিয়ে থাকে।",
          "numberInSurah": 27,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4812,
          "text": "অথচ এ বিষয়ে তাদের কোন জ্ঞান নেই। তারা কেবল অনুমানের উপর চলে। অথচ সত্যের ব্যাপারে অনুমান মোটেই ফলপ্রসূ নয়।",
          "numberInSurah": 28,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4813,
          "text": "অতএব যে আমার স্মরণে বিমুখ এবং কেবল পার্থিব জীবনই কামনা করে তার তরফ থেকে আপনি মুখ ফিরিয়ে নিন।",
          "numberInSurah": 29,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4814,
          "text": "তাদের জ্ঞানের পরিধি এ পর্যন্তই। নিশ্চয় আপনার পালনকর্তা ভাল জানেন, কে তাঁর পথ থেকে বিচ্যুত হয়েছে এবং তিনিই ভাল জানেন কে সুপথপ্রাপ্ত হয়েছে।",
          "numberInSurah": 30,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4815,
          "text": "নভোমন্ডল ও ভূমন্ডলে যা কিছু আছে, সবই আল্লাহর, যাতে তিনি মন্দকর্মীদেরকে তাদের কর্মের প্রতিফল দেন এবং সৎকর্মীদেরকে দেন ভাল ফল।",
          "numberInSurah": 31,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4816,
          "text": "যারা বড় বড় গোনাহ ও অশ্লীলকার্য থেকে বেঁচে থাকে ছোটখাট অপরাধ করলেও নিশ্চয় আপনার পালনকর্তার ক্ষমা সুদূর বিস্তৃত। তিনি তোমাদের সম্পর্কে ভাল জানেন, যখন তিনি তোমাদেরকে সৃষ্টি করেছেন মৃত্তিকা থেকে এবং যখন তোমরা মাতৃগর্ভে কচি শিশু ছিলে। অতএব তোমরা আত্নপ্রশংসা করো না। তিনি ভাল জানেন কে সংযমী।",
          "numberInSurah": 32,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 461,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4817,
          "text": "আপনি কি তাকে দেখেছেন, যে মুখ ফিরিয়ে নেয়।",
          "numberInSurah": 33,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4818,
          "text": "এবং দেয় সামান্যই ও পাষাণ হয়ে যায়।",
          "numberInSurah": 34,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4819,
          "text": "তার কাছে কি অদৃশ্যের জ্ঞান আছে যে, সে দেখে?",
          "numberInSurah": 35,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4820,
          "text": "তাকে কি জানানো হয়নি যা আছে মূসার কিতাবে,",
          "numberInSurah": 36,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4821,
          "text": "এবং ইব্রাহীমের কিতাবে, যে তার দায়িত্ব পালন করেছিল?",
          "numberInSurah": 37,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4822,
          "text": "কিতাবে এই আছে যে, কোন ব্যক্তি কারও গোনাহ নিজে বহন করবে না।",
          "numberInSurah": 38,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4823,
          "text": "এবং মানুষ তাই পায়, যা সে করে,",
          "numberInSurah": 39,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4824,
          "text": "তার কর্ম শীঘ্রই দেখা হবে।",
          "numberInSurah": 40,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4825,
          "text": "অতঃপর তাকে পূর্ণ প্রতিদান দেয়া হবে।",
          "numberInSurah": 41,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4826,
          "text": "তোমার পালনকর্তার কাছে সবকিছুর সমাপ্তি,",
          "numberInSurah": 42,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4827,
          "text": "এবং তিনিই হাসান ও কাঁদান",
          "numberInSurah": 43,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4828,
          "text": "এবং তিনিই মারেন ও বাঁচান,",
          "numberInSurah": 44,
          "juz": 27,
          "manzil": 7,
          "page": 527,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4829,
          "text": "এবং তিনিই সৃষ্টি করেন যুগল-পুরুষ ও নারী।",
          "numberInSurah": 45,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4830,
          "text": "একবিন্দু বীর্য থেকে যখন স্খলিত করা হয়।",
          "numberInSurah": 46,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4831,
          "text": "পুনরুত্থানের দায়িত্ব তাঁরই,",
          "numberInSurah": 47,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4832,
          "text": "এবং তিনিই ধনবান করেন ও সম্পদ দান করেন।",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4833,
          "text": "তিনি শিরা নক্ষত্রের মালিক।",
          "numberInSurah": 49,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4834,
          "text": "তিনিই প্রথম আদ সম্প্রদায়কে ধ্বংস করেছেন,",
          "numberInSurah": 50,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4835,
          "text": "এবং সামুদকেও; অতঃপর কাউকে অব্যহতি দেননি।",
          "numberInSurah": 51,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4836,
          "text": "এবং তাদের পূর্বে নূহের সম্প্রদায়কে, তারা ছিল আরও জালেম ও অবাধ্য।",
          "numberInSurah": 52,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4837,
          "text": "তিনিই জনপদকে শুন্যে উত্তোলন করে নিক্ষেপ করেছেন।",
          "numberInSurah": 53,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4838,
          "text": "অতঃপর তাকে আচ্ছন্ন করে নেয় যা আচ্ছন্ন করার।",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4839,
          "text": "অতঃপর তুমি তোমার পালনকর্তার কোন অনুগ্রহকে মিথ্যা বলবে?",
          "numberInSurah": 55,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4840,
          "text": "অতীতের সতর্ককারীদের মধ্যে সে-ও একজন সতর্ককারী।",
          "numberInSurah": 56,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4841,
          "text": "কেয়ামত নিকটে এসে গেছে।",
          "numberInSurah": 57,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4842,
          "text": "আল্লাহ ব্যতীত কেউ একে প্রকাশ করতে সক্ষম নয়।",
          "numberInSurah": 58,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4843,
          "text": "তোমরা কি এই বিষয়ে আশ্চর্যবোধ করছ?",
          "numberInSurah": 59,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4844,
          "text": "এবং হাসছ-ক্রন্দন করছ না?",
          "numberInSurah": 60,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4845,
          "text": "তোমরা ক্রীড়া-কৌতুক করছ,",
          "numberInSurah": 61,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4846,
          "text": "অতএব আল্লাহকে সেজদা কর এবং তাঁর এবাদত কর।",
          "numberInSurah": 62,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 462,
          "hizbQuarter": 211,
          "sajda": {
            "id": 13,
            "recommended": false,
            "obligatory": true
          }
        }
      ],
