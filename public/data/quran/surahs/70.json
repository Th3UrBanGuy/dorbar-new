    {
      "number": 70,
      "name": "سُورَةُ المَعَارِجِ",
      "englishName": "Al-Ma'aarij",
      "englishNameTranslation": "The Ascending Stairways",
      "revelationType": "Meccan",
      "numberOfAyahs": 44,
      "ayahs": [
        {
          "number": 5376,
          "text": "একব্যক্তি চাইল, সেই আযাব সংঘটিত হোক যা অবধারিত-",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5377,
          "text": "কাফেরদের জন্যে, যার প্রতিরোধকারী কেউ নেই।",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5378,
          "text": "তা আসবে আল্লাহ তা’আলার পক্ষ থেকে, যিনি সমুন্নত মর্তবার অধিকারী।",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5379,
          "text": "ফেরেশতাগণ এবং রূহ আল্লাহ তা’আলার দিকে উর্ধ্বগামী হয় এমন একদিনে, যার পরিমাণ পঞ্চাশ হাজার বছর।",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5380,
          "text": "অতএব, আপনি উত্তম সবর করুন।",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5381,
          "text": "তারা এই আযাবকে সুদূরপরাহত মনে করে,",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5382,
          "text": "আর আমি একে আসন্ন দেখছি।",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5383,
          "text": "সেদিন আকাশ হবে গলিত তামার মত।",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5384,
          "text": "এবং পর্বতসমূহ হবে রঙ্গীন পশমের মত,",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5385,
          "text": "বন্ধু বন্ধুর খবর নিবে না।",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 568,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5386,
          "text": "যদিও একে অপরকে দেখতে পাবে। সেদিন গোনাহগার ব্যক্তি পনস্বরূপ দিতে চাইবে তার সন্তান-সন্ততিকে,",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5387,
          "text": "তার স্ত্রীকে, তার ভ্রাতাকে,",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5388,
          "text": "তার গোষ্ঠীকে, যারা তাকে আশ্রয় দিত।",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5389,
          "text": "এবং পৃথিবীর সবকিছুকে, অতঃপর নিজেকে রক্ষা করতে চাইবে।",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5390,
          "text": "কখনই নয়। নিশ্চয় এটা লেলিহান অগ্নি।",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5391,
          "text": "যা চামড়া তুলে দিবে।",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5392,
          "text": "সে সেই ব্যক্তিকে ডাকবে যে সত্যের প্রতি পৃষ্ঠপ্রদর্শন করেছিল ও বিমুখ হয়েছিল।",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5393,
          "text": "সম্পদ পুঞ্জীভূত করেছিল, অতঃপর আগলিয়ে রেখেছিল।",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 227,
          "sajda": false
        },
        {
          "number": 5394,
          "text": "মানুষ তো সৃজিত হয়েছে ভীরুরূপে।",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5395,
          "text": "যখন তাকে অনিষ্ট স্পর্শ করে, তখন সে হা-হুতাশ করে।",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5396,
          "text": "আর যখন কল্যাণপ্রাপ্ত হয়, তখন কৃপণ হয়ে যায়।",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5397,
          "text": "তবে তারা স্বতন্ত্র, যারা নামায আদায় কারী।",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5398,
          "text": "যারা তাদের নামাযে সার্বক্ষণিক কায়েম থাকে।",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5399,
          "text": "এবং যাদের ধন-সম্পদে নির্ধারিত হক আছে",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5400,
          "text": "যাঞ্ছাকারী ও বঞ্চিতের",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5401,
          "text": "এবং যারা প্রতিফল দিবসকে সত্য বলে বিশ্বাস করে।",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5402,
          "text": "এবং যারা তাদের পালনকর্তার শাস্তির সম্পর্কে ভীত-কম্পিত।",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5403,
          "text": "নিশ্চয় তাদের পালনকর্তার শাস্তি থেকে নিঃশঙ্কা থাকা যায় না।",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5404,
          "text": "এবং যারা তাদের যৌন-অঙ্গকে সংযত রাখে",
          "numberInSurah": 29,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5405,
          "text": "কিন্তু তাদের স্ত্রী অথবা মালিকানাভূক্ত দাসীদের বেলায় তিরস্কৃত হবে না।",
          "numberInSurah": 30,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5406,
          "text": "অতএব, যারা এদের ছাড়া অন্যকে কামনা করে, তারাই সীমালংঘনকারী।",
          "numberInSurah": 31,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5407,
          "text": "এবং যারা তাদের আমানত ও অঙ্গীকার রক্ষা করে",
          "numberInSurah": 32,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5408,
          "text": "এবং যারা তাদের সাক্ষ্যদানে সরল-নিষ্ঠাবান",
          "numberInSurah": 33,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5409,
          "text": "এবং যারা তাদের নামাযে যত্নবান,",
          "numberInSurah": 34,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5410,
          "text": "তারাই জান্নাতে সম্মানিত হবে।",
          "numberInSurah": 35,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 502,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5411,
          "text": "অতএব, কাফেরদের কি হল যে, তারা আপনার দিকে উর্ধ্বশ্বাসে ছুটে আসছে।",
          "numberInSurah": 36,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5412,
          "text": "ডান ও বামদিক থেকে দলে দলে।",
          "numberInSurah": 37,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5413,
          "text": "তাদের প্রত্যেকেই কি আশা করে যে, তাকে নেয়ামতের জান্নাতে দাখিল করা হবে?",
          "numberInSurah": 38,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5414,
          "text": "কখনই নয়, আমি তাদেরকে এমন বস্তু দ্বারা সৃষ্টি করেছি, যা তারা জানে।",
          "numberInSurah": 39,
          "juz": 29,
          "manzil": 7,
          "page": 569,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5415,
          "text": "আমি শপথ করছি উদয়াচল ও অস্তাচলসমূহের পালনকর্তার, নিশ্চয়ই আমি সক্ষম!",
          "numberInSurah": 40,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5416,
          "text": "তাদের পরিবর্তে উৎকৃষ্টতর মানুষ সৃষ্টি করতে এবং এটা আমার সাধ্যের অতীত নয়।",
          "numberInSurah": 41,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5417,
          "text": "অতএব, আপনি তাদেরকে ছেড়ে দিন, তারা বাকবিতন্ডা ও ক্রীড়া-কৌতুক করুক সেই দিবসের সম্মুখীন হওয়া পর্যন্ত, যে দিবসের ওয়াদা তাদের সাথে করা হচ্ছে।",
          "numberInSurah": 42,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5418,
          "text": "সে দিন তারা কবর থেকে দ্রুতবেগে বের হবে, যেন তারা কোন এক লক্ষ্যস্থলের দিকে ছুটে যাচ্ছে।",
          "numberInSurah": 43,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5419,
          "text": "তাদের দৃষ্টি থাকবে অবনমিত; তারা হবে হীনতাগ্রস্ত। এটাই সেইদিন, যার ওয়াদা তাদেরকে দেয়া হত।",
          "numberInSurah": 44,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 503,
          "hizbQuarter": 228,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}