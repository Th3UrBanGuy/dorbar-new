    },
    {
      "number": 93,
      "name": "سُورَةُ الضُّحَىٰ",
      "englishName": "Ad-Dhuhaa",
      "englishNameTranslation": "The Morning Hours",
      "revelationType": "Meccan",
      "numberOfAyahs": 11,
      "ayahs": [
        {
          "number": 6080,
          "text": "শপথ পূর্বাহ্নের,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6081,
          "text": "শপথ রাত্রির যখন তা গভীর হয়,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6082,
          "text": "আপনার পালনকর্তা আপনাকে ত্যাগ করেনি এবং আপনার প্রতি বিরূপও হননি।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6083,
          "text": "আপনার জন্যে পরকাল ইহকাল অপেক্ষা শ্রেয়।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6084,
          "text": "আপনার পালনকর্তা সত্বরই আপনাকে দান করবেন, অতঃপর আপনি সন্তুষ্ট হবেন।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6085,
          "text": "তিনি কি আপনাকে এতীমরূপে পাননি? অতঃপর তিনি আশ্রয় দিয়েছেন।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6086,
          "text": "তিনি আপনাকে পেয়েছেন পথহারা, অতঃপর পথপ্রদর্শন করেছেন।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6087,
          "text": "তিনি আপনাকে পেয়েছেন নিঃস্ব, অতঃপর অভাবমুক্ত করেছেন।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6088,
          "text": "সুতরাং আপনি এতীমের প্রতি কঠোর হবেন না;",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6089,
          "text": "সওয়ালকারীকে ধমক দেবেন না।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6090,
          "text": "এবং আপনার পালনকর্তার নেয়ামতের কথা প্রকাশ করুন।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}