  "data": [
    {
      "number": 93,
      "name": "سُورَةُ الضُّحَىٰ",
      "englishName": "Ad-Dhuhaa",
      "englishNameTranslation": "The Morning Hours",
      "revelationType": "Meccan",
      "numberOfAyahs": 11,
      "ayahs": [
        {
          "number": 6080,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6081,
          "text": "وَٱلَّيْلِ إِذَا سَجَىٰ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6082,
          "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6083,
          "text": "وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6084,
          "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6085,
          "text": "أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6086,
          "text": "وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6087,
          "text": "وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6088,
          "text": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6089,
          "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6090,
          "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 535,
          "hizbQuarter": 238,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
