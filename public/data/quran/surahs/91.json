  "data": [
    {
      "number": 91,
      "name": "سُورَةُ الشَّمۡسِ",
      "englishName": "Ash-Shams",
      "englishNameTranslation": "The Sun",
      "revelationType": "Meccan",
      "numberOfAyahs": 15,
      "ayahs": [
        {
          "number": 6044,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلشَّمْسِ وَضُحَىٰهَا",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6045,
          "text": "وَٱلْقَمَرِ إِذَا تَلَىٰهَا",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6046,
          "text": "وَٱلنَّهَارِ إِذَا جَلَّىٰهَا",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6047,
          "text": "وَٱلَّيْلِ إِذَا يَغْشَىٰهَا",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6048,
          "text": "وَٱلسَّمَآءِ وَمَا بَنَىٰهَا",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6049,
          "text": "وَٱلْأَرْضِ وَمَا طَحَىٰهَا",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6050,
          "text": "وَنَفْسٍۢ وَمَا سَوَّىٰهَا",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6051,
          "text": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6052,
          "text": "قَدْ أَفْلَحَ مَن زَكَّىٰهَا",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6053,
          "text": "وَقَدْ خَابَ مَن دَسَّىٰهَا",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6054,
          "text": "كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6055,
          "text": "إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6056,
          "text": "فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَٰهَا",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6057,
          "text": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6058,
          "text": "وَلَا يَخَافُ عُقْبَٰهَا",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 91,
      "name": "سُورَةُ الشَّمۡسِ",
      "englishName": "Ash-Shams",
      "englishNameTranslation": "The Sun",
      "revelationType": "Meccan",
      "numberOfAyahs": 15,
      "ayahs": [
        {
          "number": 6044,
          "text": "শপথ সূর্যের ও তার কিরণের,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6045,
          "text": "শপথ চন্দ্রের যখন তা সূর্যের পশ্চাতে আসে,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6046,
          "text": "শপথ দিবসের যখন সে সূর্যকে প্রখরভাবে প্রকাশ করে,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6047,
          "text": "শপথ রাত্রির যখন সে সূর্যকে আচ্ছাদিত করে,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6048,
          "text": "শপথ আকাশের এবং যিনি তা নির্মাণ করেছেন, তাঁর।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6049,
          "text": "শপথ পৃথিবীর এবং যিনি তা বিস্তৃত করেছেন, তাঁর,",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6050,
          "text": "শপথ প্রাণের এবং যিনি তা সুবিন্যস্ত করেছেন, তাঁর,",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6051,
          "text": "অতঃপর তাকে তার অসৎকর্ম ও সৎকর্মের জ্ঞান দান করেছেন,",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6052,
          "text": "যে নিজেকে শুদ্ধ করে, সেই সফলকাম হয়।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6053,
          "text": "এবং যে নিজেকে কলুষিত করে, সে ব্যর্থ মনোরথ হয়।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6054,
          "text": "সামুদ সম্প্রদায় অবাধ্যতা বশতঃ মিথ্যারোপ করেছিল।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6055,
          "text": "যখন তাদের সর্বাধিক হতভাগ্য ব্যক্তি তৎপর হয়ে উঠেছিল।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6056,
          "text": "অতঃপর আল্লাহর রসূল তাদেরকে বলেছিলেনঃ আল্লাহর উষ্ট্রী ও তাকে পানি পান করানোর ব্যাপারে সতর্ক থাক।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6057,
          "text": "অতঃপর ওরা তার প্রতি মিথ্যারোপ করেছিল এবং উষ্ট্রীর পা কর্তন করেছিল। তাদের পাপের কারণে তাদের পালনকর্তা তাদের উপর ধ্বংস নাযিল করে একাকার করে দিলেন।",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        },
        {
          "number": 6058,
          "text": "আল্লাহ তা’আলা এই ধ্বংসের কোন বিরূপ পরিণতির আশংকা করেন না।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 595,
          "ruku": 533,
          "hizbQuarter": 238,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}