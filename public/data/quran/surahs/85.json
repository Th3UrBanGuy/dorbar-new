  "data": [
    {
      "number": 85,
      "name": "سُورَةُ البُرُوجِ",
      "englishName": "Al-Burooj",
      "englishNameTranslation": "The Constellations",
      "revelationType": "Meccan",
      "numberOfAyahs": 22,
      "ayahs": [
        {
          "number": 5910,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ ذَاتِ ٱلْبُرُوجِ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5911,
          "text": "وَٱلْيَوْمِ ٱلْمَوْعُودِ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5912,
          "text": "وَشَاهِدٍۢ وَمَشْهُودٍۢ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5913,
          "text": "قُتِلَ أَصْحَٰبُ ٱلْأُخْدُودِ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5914,
          "text": "ٱلنَّارِ ذَاتِ ٱلْوَقُودِ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5915,
          "text": "إِذْ هُمْ عَلَيْهَا قُعُودٌۭ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5916,
          "text": "وَهُمْ عَلَىٰ مَا يَفْعَلُونَ بِٱلْمُؤْمِنِينَ شُهُودٌۭ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5917,
          "text": "وَمَا نَقَمُوا۟ مِنْهُمْ إِلَّآ أَن يُؤْمِنُوا۟ بِٱللَّهِ ٱلْعَزِيزِ ٱلْحَمِيدِ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5918,
          "text": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍۢ شَهِيدٌ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5919,
          "text": "إِنَّ ٱلَّذِينَ فَتَنُوا۟ ٱلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ ثُمَّ لَمْ يَتُوبُوا۟ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ ٱلْحَرِيقِ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5920,
          "text": "إِنَّ ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٌۭ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَٰرُ ۚ ذَٰلِكَ ٱلْفَوْزُ ٱلْكَبِيرُ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5921,
          "text": "إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5922,
          "text": "إِنَّهُۥ هُوَ يُبْدِئُ وَيُعِيدُ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5923,
          "text": "وَهُوَ ٱلْغَفُورُ ٱلْوَدُودُ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5924,
          "text": "ذُو ٱلْعَرْشِ ٱلْمَجِيدُ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5925,
          "text": "فَعَّالٌۭ لِّمَا يُرِيدُ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5926,
          "text": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْجُنُودِ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5927,
          "text": "فِرْعَوْنَ وَثَمُودَ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5928,
          "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ فِى تَكْذِيبٍۢ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5929,
          "text": "وَٱللَّهُ مِن وَرَآئِهِم مُّحِيطٌۢ",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5930,
          "text": "بَلْ هُوَ قُرْءَانٌۭ مَّجِيدٌۭ",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5931,
          "text": "فِى لَوْحٍۢ مَّحْفُوظٍۭ",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 85,
      "name": "سُورَةُ البُرُوجِ",
      "englishName": "Al-Burooj",
      "englishNameTranslation": "The Constellations",
      "revelationType": "Meccan",
      "numberOfAyahs": 22,
      "ayahs": [
        {
          "number": 5910,
          "text": "শপথ গ্রহ-নক্ষত্র শোভিত আকাশের,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5911,
          "text": "এবং প্রতিশ্রুত দিবসের,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5912,
          "text": "এবং সেই দিবসের, যে উপস্থিত হয় ও যাতে উপস্থিত হয়",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5913,
          "text": "অভিশপ্ত হয়েছে গর্ত ওয়ালারা অর্থাৎ,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5914,
          "text": "অনেক ইন্ধনের অগ্নিসংযোগকারীরা;",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5915,
          "text": "যখন তারা তার কিনারায় বসেছিল।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5916,
          "text": "এবং তারা বিশ্বাসীদের সাথে যা করেছিল, তা নিরীক্ষণ করছিল।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5917,
          "text": "তারা তাদেরকে শাস্তি দিয়েছিল শুধু এ কারণে যে, তারা প্রশংসিত, পরাক্রান্ত আল্লাহর প্রতি বিশ্বাস স্থাপন করেছিল,",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5918,
          "text": "যিনি নভোমন্ডল ও ভূমন্ডলের ক্ষমতার মালিক, আল্লাহর সামনে রয়েছে সবকিছু।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5919,
          "text": "যারা মুমিন পুরুষ ও নারীকে নিপীড়ন করেছে, অতঃপর তওবা করেনি, তাদের জন্যে আছে জাহান্নামের শাস্তি, আর আছে দহন যন্ত্রণা,",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5920,
          "text": "যারা ঈমান আনে ও সৎকর্ম করে তাদের জন্যে আছে জান্নাত, যার তলদেশে প্রবাহিত হয় নির্ঝরিণীসমূহ। এটাই মহাসাফল্য।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5921,
          "text": "নিশ্চয় তোমার পালনকর্তার পাকড়াও অত্যন্ত কঠিন।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5922,
          "text": "তিনিই প্রথমবার অস্তিত্ব দান করেন এবং পুনরায় জীবিত করেন।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5923,
          "text": "তিনি ক্ষমাশীল, প্রেমময়;",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5924,
          "text": "মহান আরশের অধিকারী।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5925,
          "text": "তিনি যা চান, তাই করেন।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5926,
          "text": "আপনার কাছে সৈন্যবাহিনীর ইতিবৃত্ত পৌছেছে কি?",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5927,
          "text": "ফেরাউনের এবং সামুদের?",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5928,
          "text": "বরং যারা কাফের, তারা মিথ্যারোপে রত আছে।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5929,
          "text": "আল্লাহ তাদেরকে চতুর্দিক থেকে পরিবেষ্টন করে রেখেছেন।",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5930,
          "text": "বরং এটা মহান কোরআন,",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5931,
          "text": "লওহে মাহফুযে লিপিবদ্ধ।",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 590,
          "ruku": 527,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
