  "data": [
    {
      "number": 54,
      "name": "سُورَةُ القَمَرِ",
      "englishName": "Al-Qamar",
      "englishNameTranslation": "The Moon",
      "revelationType": "Meccan",
      "numberOfAyahs": 55,
      "ayahs": [
        {
          "number": 4847,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلْقَمَرُ",
          "numberInSurah": 1,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4848,
          "text": "وَإِن يَرَوْا۟ ءَايَةًۭ يُعْرِضُوا۟ وَيَقُولُوا۟ سِحْرٌۭ مُّسْتَمِرٌّۭ",
          "numberInSurah": 2,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4849,
          "text": "وَكَذَّبُوا۟ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ ۚ وَكُلُّ أَمْرٍۢ مُّسْتَقِرٌّۭ",
          "numberInSurah": 3,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4850,
          "text": "وَلَقَدْ جَآءَهُم مِّنَ ٱلْأَنۢبَآءِ مَا فِيهِ مُزْدَجَرٌ",
          "numberInSurah": 4,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4851,
          "text": "حِكْمَةٌۢ بَٰلِغَةٌۭ ۖ فَمَا تُغْنِ ٱلنُّذُرُ",
          "numberInSurah": 5,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4852,
          "text": "فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَىْءٍۢ نُّكُرٍ",
          "numberInSurah": 6,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4853,
          "text": "خُشَّعًا أَبْصَٰرُهُمْ يَخْرُجُونَ مِنَ ٱلْأَجْدَاثِ كَأَنَّهُمْ جَرَادٌۭ مُّنتَشِرٌۭ",
          "numberInSurah": 7,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4854,
          "text": "مُّهْطِعِينَ إِلَى ٱلدَّاعِ ۖ يَقُولُ ٱلْكَٰفِرُونَ هَٰذَا يَوْمٌ عَسِرٌۭ",
          "numberInSurah": 8,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4855,
          "text": "۞ كَذَّبَتْ قَبْلَهُمْ قَوْمُ نُوحٍۢ فَكَذَّبُوا۟ عَبْدَنَا وَقَالُوا۟ مَجْنُونٌۭ وَٱزْدُجِرَ",
          "numberInSurah": 9,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4856,
          "text": "فَدَعَا رَبَّهُۥٓ أَنِّى مَغْلُوبٌۭ فَٱنتَصِرْ",
          "numberInSurah": 10,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4857,
          "text": "فَفَتَحْنَآ أَبْوَٰبَ ٱلسَّمَآءِ بِمَآءٍۢ مُّنْهَمِرٍۢ",
          "numberInSurah": 11,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4858,
          "text": "وَفَجَّرْنَا ٱلْأَرْضَ عُيُونًۭا فَٱلْتَقَى ٱلْمَآءُ عَلَىٰٓ أَمْرٍۢ قَدْ قُدِرَ",
          "numberInSurah": 12,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4859,
          "text": "وَحَمَلْنَٰهُ عَلَىٰ ذَاتِ أَلْوَٰحٍۢ وَدُسُرٍۢ",
          "numberInSurah": 13,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4860,
          "text": "تَجْرِى بِأَعْيُنِنَا جَزَآءًۭ لِّمَن كَانَ كُفِرَ",
          "numberInSurah": 14,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4861,
          "text": "وَلَقَد تَّرَكْنَٰهَآ ءَايَةًۭ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 15,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4862,
          "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
          "numberInSurah": 16,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4863,
          "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 17,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4864,
          "text": "كَذَّبَتْ عَادٌۭ فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
          "numberInSurah": 18,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4865,
          "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ رِيحًۭا صَرْصَرًۭا فِى يَوْمِ نَحْسٍۢ مُّسْتَمِرٍّۢ",
          "numberInSurah": 19,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4866,
          "text": "تَنزِعُ ٱلنَّاسَ كَأَنَّهُمْ أَعْجَازُ نَخْلٍۢ مُّنقَعِرٍۢ",
          "numberInSurah": 20,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4867,
          "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
          "numberInSurah": 21,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4868,
          "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 22,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4869,
          "text": "كَذَّبَتْ ثَمُودُ بِٱلنُّذُرِ",
          "numberInSurah": 23,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4870,
          "text": "فَقَالُوٓا۟ أَبَشَرًۭا مِّنَّا وَٰحِدًۭا نَّتَّبِعُهُۥٓ إِنَّآ إِذًۭا لَّفِى ضَلَٰلٍۢ وَسُعُرٍ",
          "numberInSurah": 24,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4871,
          "text": "أَءُلْقِىَ ٱلذِّكْرُ عَلَيْهِ مِنۢ بَيْنِنَا بَلْ هُوَ كَذَّابٌ أَشِرٌۭ",
          "numberInSurah": 25,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4872,
          "text": "سَيَعْلَمُونَ غَدًۭا مَّنِ ٱلْكَذَّابُ ٱلْأَشِرُ",
          "numberInSurah": 26,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4873,
          "text": "إِنَّا مُرْسِلُوا۟ ٱلنَّاقَةِ فِتْنَةًۭ لَّهُمْ فَٱرْتَقِبْهُمْ وَٱصْطَبِرْ",
          "numberInSurah": 27,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4874,
          "text": "وَنَبِّئْهُمْ أَنَّ ٱلْمَآءَ قِسْمَةٌۢ بَيْنَهُمْ ۖ كُلُّ شِرْبٍۢ مُّحْتَضَرٌۭ",
          "numberInSurah": 28,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4875,
          "text": "فَنَادَوْا۟ صَاحِبَهُمْ فَتَعَاطَىٰ فَعَقَرَ",
          "numberInSurah": 29,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4876,
          "text": "فَكَيْفَ كَانَ عَذَابِى وَنُذُرِ",
          "numberInSurah": 30,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4877,
          "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ صَيْحَةًۭ وَٰحِدَةًۭ فَكَانُوا۟ كَهَشِيمِ ٱلْمُحْتَظِرِ",
          "numberInSurah": 31,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4878,
          "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 32,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4879,
          "text": "كَذَّبَتْ قَوْمُ لُوطٍۭ بِٱلنُّذُرِ",
          "numberInSurah": 33,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4880,
          "text": "إِنَّآ أَرْسَلْنَا عَلَيْهِمْ حَاصِبًا إِلَّآ ءَالَ لُوطٍۢ ۖ نَّجَّيْنَٰهُم بِسَحَرٍۢ",
          "numberInSurah": 34,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4881,
          "text": "نِّعْمَةًۭ مِّنْ عِندِنَا ۚ كَذَٰلِكَ نَجْزِى مَن شَكَرَ",
          "numberInSurah": 35,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4882,
          "text": "وَلَقَدْ أَنذَرَهُم بَطْشَتَنَا فَتَمَارَوْا۟ بِٱلنُّذُرِ",
          "numberInSurah": 36,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4883,
          "text": "وَلَقَدْ رَٰوَدُوهُ عَن ضَيْفِهِۦ فَطَمَسْنَآ أَعْيُنَهُمْ فَذُوقُوا۟ عَذَابِى وَنُذُرِ",
          "numberInSurah": 37,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4884,
          "text": "وَلَقَدْ صَبَّحَهُم بُكْرَةً عَذَابٌۭ مُّسْتَقِرٌّۭ",
          "numberInSurah": 38,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4885,
          "text": "فَذُوقُوا۟ عَذَابِى وَنُذُرِ",
          "numberInSurah": 39,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4886,
          "text": "وَلَقَدْ يَسَّرْنَا ٱلْقُرْءَانَ لِلذِّكْرِ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 40,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4887,
          "text": "وَلَقَدْ جَآءَ ءَالَ فِرْعَوْنَ ٱلنُّذُرُ",
          "numberInSurah": 41,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4888,
          "text": "كَذَّبُوا۟ بِـَٔايَٰتِنَا كُلِّهَا فَأَخَذْنَٰهُمْ أَخْذَ عَزِيزٍۢ مُّقْتَدِرٍ",
          "numberInSurah": 42,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4889,
          "text": "أَكُفَّارُكُمْ خَيْرٌۭ مِّنْ أُو۟لَٰٓئِكُمْ أَمْ لَكُم بَرَآءَةٌۭ فِى ٱلزُّبُرِ",
          "numberInSurah": 43,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4890,
          "text": "أَمْ يَقُولُونَ نَحْنُ جَمِيعٌۭ مُّنتَصِرٌۭ",
          "numberInSurah": 44,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4891,
          "text": "سَيُهْزَمُ ٱلْجَمْعُ وَيُوَلُّونَ ٱلدُّبُرَ",
          "numberInSurah": 45,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4892,
          "text": "بَلِ ٱلسَّاعَةُ مَوْعِدُهُمْ وَٱلسَّاعَةُ أَدْهَىٰ وَأَمَرُّ",
          "numberInSurah": 46,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4893,
          "text": "إِنَّ ٱلْمُجْرِمِينَ فِى ضَلَٰلٍۢ وَسُعُرٍۢ",
          "numberInSurah": 47,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4894,
          "text": "يَوْمَ يُسْحَبُونَ فِى ٱلنَّارِ عَلَىٰ وُجُوهِهِمْ ذُوقُوا۟ مَسَّ سَقَرَ",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4895,
          "text": "إِنَّا كُلَّ شَىْءٍ خَلَقْنَٰهُ بِقَدَرٍۢ",
          "numberInSurah": 49,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4896,
          "text": "وَمَآ أَمْرُنَآ إِلَّا وَٰحِدَةٌۭ كَلَمْحٍۭ بِٱلْبَصَرِ",
          "numberInSurah": 50,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4897,
          "text": "وَلَقَدْ أَهْلَكْنَآ أَشْيَاعَكُمْ فَهَلْ مِن مُّدَّكِرٍۢ",
          "numberInSurah": 51,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4898,
          "text": "وَكُلُّ شَىْءٍۢ فَعَلُوهُ فِى ٱلزُّبُرِ",
          "numberInSurah": 52,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4899,
          "text": "وَكُلُّ صَغِيرٍۢ وَكَبِيرٍۢ مُّسْتَطَرٌ",
          "numberInSurah": 53,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4900,
          "text": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّٰتٍۢ وَنَهَرٍۢ",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4901,
          "text": "فِى مَقْعَدِ صِدْقٍ عِندَ مَلِيكٍۢ مُّقْتَدِرٍۭ",
          "numberInSurah": 55,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 54,
      "name": "سُورَةُ القَمَرِ",
      "englishName": "Al-Qamar",
      "englishNameTranslation": "The Moon",
      "revelationType": "Meccan",
      "numberOfAyahs": 55,
      "ayahs": [
        {
          "number": 4847,
          "text": "কেয়ামত আসন্ন, চন্দ্র বিদীর্ণ হয়েছে।",
          "numberInSurah": 1,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4848,
          "text": "তারা যদি কোন নিদর্শন দেখে তবে মুখ ফিরিয়ে নেয় এবং বলে, এটা তো চিরাগত জাদু।",
          "numberInSurah": 2,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4849,
          "text": "তারা মিথ্যারোপ করছে এবং নিজেদের খেয়াল-খুশীর অনুসরণ করছে। প্রত্যেক কাজ যথাসময়ে স্থিরীকৃত হয়।",
          "numberInSurah": 3,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4850,
          "text": "তাদের কাছে এমন সংবাদ এসে গেছে, যাতে সাবধানবাণী রয়েছে।",
          "numberInSurah": 4,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4851,
          "text": "এটা পরিপূর্ণ জ্ঞান, তবে সতর্ককারীগণ তাদের কোন উপকারে আসে না।",
          "numberInSurah": 5,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4852,
          "text": "অতএব, আপনি তাদের থেকে মুখ ফিরিয়ে নিন। যেদিন আহবানকারী আহবান করবে এক অপ্রিয় পরিণামের দিকে,",
          "numberInSurah": 6,
          "juz": 27,
          "manzil": 7,
          "page": 528,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4853,
          "text": "তারা তখন অবনমিত নেত্রে কবর থেকে বের হবে বিক্ষিপ্ত পংগপাল সদৃশ।",
          "numberInSurah": 7,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4854,
          "text": "তারা আহবানকারীর দিকে দৌড়াতে থাকবে। কাফেরা বলবেঃ এটা কঠিন দিন।",
          "numberInSurah": 8,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 211,
          "sajda": false
        },
        {
          "number": 4855,
          "text": "তাদের পূর্বে নূহের সম্প্রদায়ও মিথ্যারোপ করেছিল। তারা মিথ্যারোপ করেছিল আমার বান্দা নূহের প্রতি এবং বলেছিলঃ এ তো উম্মাদ। তাঁরা তাকে হুমকি প্রদর্শন করেছিল।",
          "numberInSurah": 9,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4856,
          "text": "অতঃপর সে তার পালনকর্তাকে ডেকে বললঃ আমি অক্ষম, অতএব, তুমি প্রতিবিধান কর।",
          "numberInSurah": 10,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4857,
          "text": "তখন আমি খুলে দিলাম আকাশের দ্বার প্রবল বারিবর্ষণের মাধ্যমে।",
          "numberInSurah": 11,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4858,
          "text": "এবং ভুমি থেকে প্রবাহিত করলাম প্রস্রবণ। অতঃপর সব পানি মিলিত হল এক পরিকম্পিত কাজে।",
          "numberInSurah": 12,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4859,
          "text": "আমি নূহকে আরোহণ করালাম এক কাষ্ঠ ও পেরেক নির্মিত জলযানে।",
          "numberInSurah": 13,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4860,
          "text": "যা চলত আমার দৃষ্টি সামনে। এটা তার পক্ষ থেকে প্রতিশোধ ছিল, যাকে প্রত্যখ্যান করা হয়েছিল।",
          "numberInSurah": 14,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4861,
          "text": "আমি একে এক নিদর্শনরূপে রেখে দিয়েছি। অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 15,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4862,
          "text": "কেমন কঠোর ছিল আমার শাস্তি ও সতর্কবাণী।",
          "numberInSurah": 16,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4863,
          "text": "আমি কোরআনকে সহজ করে দিয়েছি বোঝার জন্যে। অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 17,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4864,
          "text": "আদ সম্প্রদায় মিথ্যারোপ করেছিল, অতঃপর কেমন কঠোর হয়েছিল আমার শাস্তি ও সতর্কবাণী।",
          "numberInSurah": 18,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4865,
          "text": "আমি তাদের উপর প্রেরণ করেছিলাম ঝঞ্জাবায়ু এক চিরাচরিত অশুভ দিনে।",
          "numberInSurah": 19,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4866,
          "text": "তা মানুষকে উৎখাত করছিল, যেন তারা উৎপাটিত খর্জুর বৃক্ষের কান্ড।",
          "numberInSurah": 20,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4867,
          "text": "অতঃপর কেমন কঠোর ছিল আমার শাস্তি ও সতর্কবাণী।",
          "numberInSurah": 21,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4868,
          "text": "আমি কোরআনকে বোঝার জন্যে সহজ করে দিয়েছি। অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 22,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 463,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4869,
          "text": "সামুদ সম্প্রদায় সতর্ককারীদের প্রতি মিথ্যারোপ করেছিল।",
          "numberInSurah": 23,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4870,
          "text": "তারা বলেছিলঃ আমরা কি আমাদেরই একজনের অনুসরণ করব? তবে তো আমরা বিপথগামী ও বিকার গ্রস্থরূপে গণ্য হব।",
          "numberInSurah": 24,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4871,
          "text": "আমাদের মধ্যে কি তারই প্রতি উপদেশ নাযিল করা হয়েছে? বরং সে একজন মিথ্যাবাদী, দাম্ভিক।",
          "numberInSurah": 25,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4872,
          "text": "এখন আগামীকল্যই তারা জানতে পারবে কে মিথ্যাবাদী, দাম্ভিক।",
          "numberInSurah": 26,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4873,
          "text": "আমি তাদের পরীক্ষার জন্য এক উষ্ট্রী প্রেরণ করব, অতএব, তাদের প্রতি লক্ষ্য রাখ এবং সবর কর।",
          "numberInSurah": 27,
          "juz": 27,
          "manzil": 7,
          "page": 529,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4874,
          "text": "এবং তাদেরকে জানিয়ে দাও যে, তাদের মধ্যে পানির পালা নির্ধারিত হয়েছে এবং পালাক্রমে উপস্থিত হতে হবে।",
          "numberInSurah": 28,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4875,
          "text": "অতঃপর তারা তাদের সঙ্গীকে ডাকল। সে তাকে ধরল এবং বধ করল।",
          "numberInSurah": 29,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4876,
          "text": "অতঃপর কেমন কঠোর ছিল আমার শাস্তি ও সতর্কবাণী।",
          "numberInSurah": 30,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4877,
          "text": "আমি তাদের প্রতি একটিমাত্র নিনাদ প্রেরণ করেছিলাম। এতেই তারা হয়ে গেল শুষ্ক শাখাপল্লব নির্মিত দলিত খোয়াড়ের ন্যায়।",
          "numberInSurah": 31,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4878,
          "text": "আমি কোরআনকে বোঝার জন্যে সহজ করে দিয়েছি। অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 32,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4879,
          "text": "লূত-সম্প্রদায় সতর্ককারীদের প্রতি মিথ্যারোপ করেছিল।",
          "numberInSurah": 33,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4880,
          "text": "আমি তাদের প্রতি প্রেরণ করেছিলাম প্রস্তর বর্ষণকারী প্রচন্ড ঘূর্ণিবায়ু; কিন্তু লূত পরিবারের উপর নয়। আমি তাদেরকে রাতের শেষপ্রহরে উদ্ধার করেছিলাম।",
          "numberInSurah": 34,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4881,
          "text": "আমার পক্ষ থেকে অনুগ্রহ স্বরূপ। যারা কৃতজ্ঞতা স্বীকার করে, আমি তাদেরকে এভাবে পুরস্কৃত করে থকি।",
          "numberInSurah": 35,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4882,
          "text": "লূত (আঃ) তাদেরকে আমার প্রচন্ড পাকড়াও সম্পর্কে সতর্ক করেছিল। অতঃপর তারা সতর্কবাণী সম্পর্কে বাকবিতন্ডা করেছিল।",
          "numberInSurah": 36,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4883,
          "text": "তারা লূতের (আঃ) কাছে তার মেহমানদেরকে দাবী করেছিল। তখন আমি তাদের চক্ষু লোপ করে দিলাম। অতএব, আস্বাদন কর আমার শাস্তি ও সতর্কবাণী।",
          "numberInSurah": 37,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4884,
          "text": "তাদেরকে প্রত্যুষে নির্ধারিত শাস্তি আঘাত হেনেছিল।",
          "numberInSurah": 38,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4885,
          "text": "অতএব, আমার শাস্তি ও সতর্কবাণী আস্বাদন কর।",
          "numberInSurah": 39,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4886,
          "text": "আমি কোরআনকে বোঝবার জন্যে সহজ করে দিয়েছি। অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 40,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 464,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4887,
          "text": "ফেরাউন সম্প্রদায়ের কাছেও সতর্ককারীগণ আগমন করেছিল।",
          "numberInSurah": 41,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4888,
          "text": "তারা আমার সকল নিদর্শনের প্রতি মিথ্যারোপ করেছিল। অতঃপর আমি পরাভূতকারী, পরাক্রমশালীর ন্যায় তাদেরকে পাকড়াও করলাম।",
          "numberInSurah": 42,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4889,
          "text": "তোমাদের মধ্যকার কাফেররা কি তাদের চাইতে শ্রেষ্ঠ ? না তোমাদের মুক্তির সনদপত্র রয়েছে কিতাবসমূহে?",
          "numberInSurah": 43,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4890,
          "text": "না তারা বলে যে, আমারা এক অপরাজেয় দল?",
          "numberInSurah": 44,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4891,
          "text": "এ দল তো সত্ত্বরই পরাজিত হবে এবং পৃষ্ঠপ্রদর্শন করবে।",
          "numberInSurah": 45,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4892,
          "text": "বরং কেয়ামত তাদের প্রতিশ্রুত সময় এবং কেয়ামত ঘোরতর বিপদ ও তিক্ততর।",
          "numberInSurah": 46,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4893,
          "text": "নিশ্চয় অপরাধীরা পথভ্রষ্ট ও বিকারগ্রস্ত।",
          "numberInSurah": 47,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4894,
          "text": "যেদিন তাদেরকে মুখ হিঁচড়ে টেনে নেয়া হবে জাহান্নামে, বলা হবেঃ অগ্নির খাদ্য আস্বাদন কর।",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4895,
          "text": "আমি প্রত্যেক বস্তুকে পরিমিতরূপে সৃষ্টি করেছি।",
          "numberInSurah": 49,
          "juz": 27,
          "manzil": 7,
          "page": 530,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4896,
          "text": "আমার কাজ তো এক মুহূর্তে চোখের পলকের মত।",
          "numberInSurah": 50,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4897,
          "text": "আমি তোমাদের সমমনা লোকদেরকে ধ্বংস করেছি, অতএব, কোন চিন্তাশীল আছে কি?",
          "numberInSurah": 51,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4898,
          "text": "তারা যা কিছু করেছে, সবই আমলনামায় লিপিবদ্ধ আছে।",
          "numberInSurah": 52,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4899,
          "text": "ছোট ও বড় সবই লিপিবদ্ধ।",
          "numberInSurah": 53,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4900,
          "text": "খোদাভীরুরা থাকবে জান্নাতে ও নির্ঝরিণীতে।",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        },
        {
          "number": 4901,
          "text": "যোগ্য আসনে, সর্বাধিপতি সম্রাটের সান্নিধ্যে।",
          "numberInSurah": 55,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 465,
          "hizbQuarter": 212,
          "sajda": false
        }
      ],
