  "status": "OK",
  "data": [
    {
      "number": 87,
      "name": "سُورَةُ الأَعۡلَىٰ",
      "englishName": "Al-A'laa",
      "englishNameTranslation": "The Most High",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 5949,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5950,
          "text": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5951,
          "text": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5952,
          "text": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5953,
          "text": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5954,
          "text": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5955,
          "text": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5956,
          "text": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5957,
          "text": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5958,
          "text": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5959,
          "text": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5960,
          "text": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5961,
          "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5962,
          "text": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5963,
          "text": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5964,
          "text": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5965,
          "text": "وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5966,
          "text": "إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5967,
          "text": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 87,
      "name": "سُورَةُ الأَعۡلَىٰ",
      "englishName": "Al-A'laa",
      "englishNameTranslation": "The Most High",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 5949,
          "text": "আপনি আপনার মহান পালনকর্তার নামের পবিত্রতা বর্ণনা করুন",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5950,
          "text": "যিনি সৃষ্টি করেছেন ও সুবিন্যস্ত করেছেন।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5951,
          "text": "এবং যিনি সুপরিমিত করেছেন ও পথ প্রদর্শন করেছেন",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5952,
          "text": "এবং যিনি তৃণাদি উৎপন্ন করেছেন,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5953,
          "text": "অতঃপর করেছেন তাকে কাল আবর্জনা।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5954,
          "text": "আমি আপনাকে পাঠ করাতে থাকব, ফলে আপনি বিস্মৃত হবেন না",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5955,
          "text": "আল্লাহ যা ইচ্ছা করেন তা ব্যতীত। নিশ্চয় তিনি জানেন প্রকাশ্য ও গোপন বিষয়।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5956,
          "text": "আমি আপনার জন্যে সহজ শরীয়ত সহজতর করে দেবো।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5957,
          "text": "উপদেশ ফলপ্রসূ হলে উপদেশ দান করুন,",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5958,
          "text": "যে ভয় করে, সে উপদেশ গ্রহণ করবে,",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5959,
          "text": "আর যে, হতভাগা, সে তা উপেক্ষা করবে,",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5960,
          "text": "সে মহা-অগ্নিতে প্রবেশ করবে।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5961,
          "text": "অতঃপর সেখানে সে মরবেও না, জীবিতও থাকবে না।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5962,
          "text": "নিশ্চয় সাফল্য লাভ করবে সে, যে শুদ্ধ হয়",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5963,
          "text": "এবং তার পালনকর্তার নাম স্মরণ করে, অতঃপর নামায আদায় করে।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5964,
          "text": "বস্তুতঃ তোমরা পার্থিব জীবনকে অগ্রাধিকার দাও,",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5965,
          "text": "অথচ পরকালের জীবন উৎকৃষ্ট ও স্থায়ী।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5966,
          "text": "এটা লিখিত রয়েছে পূর্ববতী কিতাবসমূহে;",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5967,
          "text": "ইব্রাহীম ও মূসার কিতাবসমূহে।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 529,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
      "edition": {
