          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6096,
          "text": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
