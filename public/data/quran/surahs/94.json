    },
    {
      "number": 94,
      "name": "سُورَةُ الشَّرۡحِ",
      "englishName": "Ash-Sharh",
      "englishNameTranslation": "The Consolation",
      "revelationType": "Meccan",
      "numberOfAyahs": 8,
      "ayahs": [
        {
          "number": 6091,
          "text": "আমি কি আপনার বক্ষ উম্মুক্ত করে দেইনি?",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6092,
          "text": "আমি লাঘব করেছি আপনার বোঝা,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6093,
          "text": "যা ছিল আপনার জন্যে অতিশয় দুঃসহ।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6094,
          "text": "আমি আপনার আলোচনাকে সমুচ্চ করেছি।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6095,
          "text": "নিশ্চয় কষ্টের সাথে স্বস্তি রয়েছে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6096,
          "text": "নিশ্চয় কষ্টের সাথে স্বস্তি রয়েছে।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6097,
          "text": "অতএব, যখন অবসর পান পরিশ্রম করুন।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6098,
          "text": "এবং আপনার পালনকর্তার প্রতি মনোনিবেশ করুন।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 596,
          "ruku": 536,
          "hizbQuarter": 239,
          "sajda": false
        }
