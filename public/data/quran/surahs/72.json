      }
    },
    {
      "number": 72,
      "name": "سُورَةُ الجِنِّ",
      "englishName": "Al-Jinn",
      "englishNameTranslation": "The Jinn",
      "revelationType": "Meccan",
      "numberOfAyahs": 28,
      "ayahs": [
        {
          "number": 5448,
          "text": "বলুনঃ আমার প্রতি ওহী নাযিল করা হয়েছে যে, জিনদের একটি দল কোরআন শ্রবণ করেছে, অতঃপর তারা বলেছেঃ আমরা বিস্ময়কর কোরআন শ্রবণ করেছি;",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5449,
          "text": "যা সৎপথ প্রদর্শন করে। ফলে আমরা তাতে বিশ্বাস স্থাপন করেছি। আমরা কখনও আমাদের পালনকর্তার সাথে কাউকে শরীক করব না।",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5450,
          "text": "এবং আরও বিশ্বাস করি যে, আমাদের পালনকর্তার মহান মর্যাদা সবার উর্ধ্বে। তিনি কোন পত্নী গ্রহণ করেননি এবং তাঁর কোন সন্তান নেই।",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5451,
          "text": "আমাদের মধ্যে নির্বোধেরা আল্লাহ তা’আলা সম্পর্কে বাড়াবাড়ির কথাবার্তা বলত।",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5452,
          "text": "অথচ আমরা মনে করতাম, মানুষ ও জিন কখনও আল্লাহ তা’আলা সম্পর্কে মিথ্যা বলতে পারে না।",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5453,
          "text": "অনেক মানুষ অনেক জিনের আশ্রয় নিত, ফলে তারা জিনদের আত্নম্ভরিতা বাড়িয়ে দিত।",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5454,
          "text": "তারা ধারণা করত, যেমন তোমরা মানবেরা ধারণা কর যে, মৃত্যুর পর আল্লাহ তা’আলা কখনও কাউকে পুনরুত্থিত করবেন না।",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5455,
          "text": "আমরা আকাশ পর্যবেক্ষণ করছি, অতঃপর দেখতে পেয়েছি যে, কঠোর প্রহরী ও উল্কাপিন্ড দ্বারা আকাশ পরিপূর্ণ।",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5456,
          "text": "আমরা আকাশের বিভিন্ন ঘাঁটিতে সংবাদ শ্রবণার্থে বসতাম। এখন কেউ সংবাদ শুনতে চাইলে সে জলন্ত উল্কাপিন্ড ওঁৎ পেতে থাকতে দেখে।",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5457,
          "text": "আমরা জানি না পৃথিবীবাসীদের অমঙ্গল সাধন করা অভীষ্ট, না তাদের পালনকর্তা তাদের মঙ্গল সাধন করার ইচ্ছা রাখেন।",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5458,
          "text": "আমাদের কেউ কেউ সৎকর্মপরায়ণ এবং কেউ কেউ এরূপ নয়। আমরা ছিলাম বিভিন্ন পথে বিভক্ত।",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5459,
          "text": "আমরা বুঝতে পেরেছি যে, আমরা পৃথিবীতে আল্লাহ তা’আলাকে পরাস্ত করতে পারব না এবং পলায়ন করেও তাকে অপারক করত পরব না।",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5460,
          "text": "আমরা যখন সুপথের নির্দেশ শুনলাম, তখন তাতে বিশ্বাস স্থাপন করলাম। অতএব, যে তার পালনকর্তার প্রতি বিশ্বাস করে, সে লোকসান ও জোর-জবরের আশংকা করে না।",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 572,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5461,
          "text": "আমাদের কিছুসংখ্যক আজ্ঞাবহ এবং কিছুসংখ্যক অন্যায়কারী। যারা আজ্ঞাবহ হয়, তারা সৎপথ বেছে নিয়েছে।",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5462,
          "text": "আর যারা অন্যায়কারী, তারা তো জাহান্নামের ইন্ধন।",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5463,
          "text": "আর এই প্রত্যাদেশ করা হয়েছে যে, তারা যদি সত্যপথে কায়েম থাকত, তবে আমি তাদেরকে প্রচুর পানি বর্ষণে সিক্ত করতাম।",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5464,
          "text": "যাতে এ ব্যাপারে তাদেরকে পরীক্ষা করি। পক্ষান্তরে যে ব্যক্তি তার পালনকর্তার স্মরণ থেকে মুখ ফিরিয়ে নেয়, তিনি তাকে উদীয়মান আযাবে পরিচালিত করবেন।",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5465,
          "text": "এবং এই ওহীও করা হয়েছে যে, মসজিদসমূহ আল্লাহ তা’আলাকে স্মরণ করার জন্য। অতএব, তোমরা আল্লাহ তা’আলার সাথে কাউকে ডেকো না।",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5466,
          "text": "আর যখন আল্লাহ তা’আলার বান্দা তাঁকে ডাকার জন্যে দন্ডায়মান হল, তখন অনেক জিন তার কাছে ভিড় জমাল।",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 506,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5467,
          "text": "বলুনঃ আমি তো আমার পালনকর্তাকেই ডাকি এবং তাঁর সাথে কাউকে শরীক করি না।",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5468,
          "text": "বলুনঃ আমি তোমাদের ক্ষতি সাধন করার ও সুপথে আনয়ন করার মালিক নই।",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5469,
          "text": "বলুনঃ আল্লাহ তা’আলার কবল থেকে আমাকে কেউ রক্ষা করতে পারবে না এবং তিনি ব্যতীত আমি কোন আশ্রয়স্থল পাব না।",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5470,
          "text": "কিন্তু আল্লাহ তা’আলার বাণী পৌছানো ও তাঁর পয়গাম প্রচার করাই আমার কাজ। যে আল্লাহ ও তাঁর রসূলকে অমান্য করে, তার জন্যে রয়েছে জাহান্নামের অগ্নি। তথায় তারা চিরকাল থাকবে।",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5471,
          "text": "এমনকি যখন তারা প্রতিশ্রুত শাস্তি দেখতে পাবে, তখন তারা জানতে পারবে, কার সাহায্যকারী দূর্বল এবং কার সংখ্যা কম।",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5472,
          "text": "বলুনঃ আমি জানি না তোমাদের প্রতিশ্রুত বিষয় আসন্ন না আমার পালনকর্তা এর জন্যে কোন মেয়াদ স্থির করে রেখেছেন।",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5473,
          "text": "তিনি অদৃশ্যের জ্ঞানী। পরন্ত তিনি অদৃশ্য বিষয় কারও কাছে প্রকাশ করেন না।",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5474,
          "text": "তাঁর মনোনীত রসূল ব্যতীত। তখন তিনি তার অগ্রে ও পশ্চাতে প্রহরী নিযুক্ত করেন",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        },
        {
          "number": 5475,
          "text": "যাতে আল্লাহ তা’আলা জেনে নেন যে, রসূলগণ তাঁদের পালনকর্তার পয়গাম পৌছিয়েছেন কি না। রসূলগণের কাছে যা আছে, তা তাঁর জ্ঞান-গোচর। তিনি সবকিছুর সংখ্যার হিসাব রাখেন।",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 573,
          "ruku": 507,
          "hizbQuarter": 229,
          "sajda": false
        }
      ],
