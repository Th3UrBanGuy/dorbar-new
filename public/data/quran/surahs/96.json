  "data": [
    {
      "number": 96,
      "name": "سُورَةُ العَلَقِ",
      "englishName": "Al-Alaq",
      "englishNameTranslation": "The Clot",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 6107,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6108,
          "text": "خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6109,
          "text": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6110,
          "text": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6111,
          "text": "عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6112,
          "text": "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6113,
          "text": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6114,
          "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6115,
          "text": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6116,
          "text": "عَبْدًا إِذَا صَلَّىٰٓ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6117,
          "text": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6118,
          "text": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6119,
          "text": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6120,
          "text": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6121,
          "text": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6122,
          "text": "نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6123,
          "text": "فَلْيَدْعُ نَادِيَهُۥ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6124,
          "text": "سَنَدْعُ ٱلزَّبَانِيَةَ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6125,
          "text": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": {
            "id": 15,
            "recommended": false,
            "obligatory": true
          }
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 96,
      "name": "سُورَةُ العَلَقِ",
      "englishName": "Al-Alaq",
      "englishNameTranslation": "The Clot",
      "revelationType": "Meccan",
      "numberOfAyahs": 19,
      "ayahs": [
        {
          "number": 6107,
          "text": "পাঠ করুন আপনার পালনকর্তার নামে যিনি সৃষ্টি করেছেন",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6108,
          "text": "সৃষ্টি করেছেন মানুষকে জমাট রক্ত থেকে।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6109,
          "text": "পাঠ করুন, আপনার পালনকর্তা মহা দয়ালু,",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6110,
          "text": "যিনি কলমের সাহায্যে শিক্ষা দিয়েছেন,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6111,
          "text": "শিক্ষা দিয়েছেন মানুষকে যা সে জানত না।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6112,
          "text": "সত্যি সত্যি মানুষ সীমালংঘন করে,",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6113,
          "text": "এ কারণে যে, সে নিজেকে অভাবমুক্ত মনে করে।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6114,
          "text": "নিশ্চয় আপনার পালনকর্তার দিকেই প্রত্যাবর্তন হবে।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6115,
          "text": "আপনি কি তাকে দেখেছেন, যে নিষেধ করে",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6116,
          "text": "এক বান্দাকে যখন সে নামায পড়ে?",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6117,
          "text": "আপনি কি দেখেছেন যদি সে সৎপথে থাকে।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6118,
          "text": "অথবা খোদাভীতি শিক্ষা দেয়।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6119,
          "text": "আপনি কি দেখেছেন, যদি সে মিথ্যারোপ করে ও মুখ ফিরিয়ে নেয়।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6120,
          "text": "সে কি জানে না যে, আল্লাহ দেখেন?",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6121,
          "text": "কখনই নয়, যদি সে বিরত না হয়, তবে আমি মস্তকের সামনের কেশগুচ্ছ ধরে হেঁচড়াবই-",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6122,
          "text": "মিথ্যাচারী, পাপীর কেশগুচ্ছ।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6123,
          "text": "অতএব, সে তার সভাসদদেরকে আহবান করুক।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6124,
          "text": "আমিও আহবান করব জাহান্নামের প্রহরীদেরকে",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6125,
          "text": "কখনই নয়, আপনি তার আনুগত্য করবেন না। আপনি সেজদা করুন ও আমার নৈকট্য অর্জন করুন।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 597,
          "ruku": 538,
          "hizbQuarter": 239,
          "sajda": {
            "id": 15,
            "recommended": false,
            "obligatory": true
          }
        }
      ],
