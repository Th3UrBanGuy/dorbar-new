          "number": 4955,
          "text": "তারা তথায় রেশমের আস্তরবিশিষ্ট বিছানায় হেলান দিয়ে বসবে। উভয় উদ্যানের ফল তাদের নিকট ঝুলবে।",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 533,
          "ruku": 468,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
