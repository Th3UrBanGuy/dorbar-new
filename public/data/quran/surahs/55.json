    {
      "number": 55,
      "name": "سُورَةُ الرَّحۡمَٰن",
      "englishName": "Ar-Rahmaan",
      "englishNameTranslation": "The Beneficent",
      "revelationType": "Medinan",
      "numberOfAyahs": 78,
      "ayahs": [
        {
          "number": 4902,
          "text": "করুনাময় আল্লাহ।",
          "numberInSurah": 1,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4903,
          "text": "শিক্ষা দিয়েছেন কোরআন,",
          "numberInSurah": 2,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4904,
          "text": "সৃষ্টি করেছেন মানুষ,",
          "numberInSurah": 3,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4905,
          "text": "তাকে শিখিয়েছেন বর্ণনা।",
          "numberInSurah": 4,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4906,
          "text": "সূর্য ও চন্দ্র হিসাবমত চলে।",
          "numberInSurah": 5,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4907,
          "text": "এবং তৃণলতা ও বৃক্ষাদি সেজদারত আছে।",
          "numberInSurah": 6,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4908,
          "text": "তিনি আকাশকে করেছেন সমুন্নত এবং স্থাপন করেছেন তুলাদন্ড।",
          "numberInSurah": 7,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4909,
          "text": "যাতে তোমরা সীমালংঘন না কর তুলাদন্ডে।",
          "numberInSurah": 8,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4910,
          "text": "তোমরা ন্যায্য ওজন কায়েম কর এবং ওজনে কম দিয়ো না।",
          "numberInSurah": 9,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4911,
          "text": "তিনি পৃথিবীকে স্থাপন করেছেন সৃষ্টজীবের জন্যে।",
          "numberInSurah": 10,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4912,
          "text": "এতে আছে ফলমূল এবং বহিরাবরণবিশিষ্ট খর্জুর বৃক্ষ।",
          "numberInSurah": 11,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4913,
          "text": "আর আছে খোসাবিশিষ্ট শস্য ও সুগন্ধি ফুল।",
          "numberInSurah": 12,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4914,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অনুগ্রহকে অস্বীকার করবে?",
          "numberInSurah": 13,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4915,
          "text": "তিনি মানুষকে সৃষ্টি করেছেন পোড়া মাটির ন্যায় শুষ্ক মৃত্তিকা থেকে।",
          "numberInSurah": 14,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4916,
          "text": "এবং জিনকে সৃষ্টি করেছেন অগ্নিশিখা থেকে।",
          "numberInSurah": 15,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4917,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অনুগ্রহ অস্বীকার করবে?",
          "numberInSurah": 16,
          "juz": 27,
          "manzil": 7,
          "page": 531,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4918,
          "text": "তিনি দুই উদয়াচল ও দুই অস্তাচলের মালিক।",
          "numberInSurah": 17,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4919,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অবদানকে অস্বীকার করবে?",
          "numberInSurah": 18,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4920,
          "text": "তিনি পাশাপাশি দুই দরিয়া প্রবাহিত করেছেন।",
          "numberInSurah": 19,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4921,
          "text": "উভয়ের মাঝখানে রয়েছে এক অন্তরাল, যা তারা অতিক্রম করে না।",
          "numberInSurah": 20,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4922,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অবদানকে অস্বীকার করবে?",
          "numberInSurah": 21,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4923,
          "text": "উভয় দরিয়া থেকে উৎপন্ন হয় মোতি ও প্রবাল।",
          "numberInSurah": 22,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4924,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অবদানকে অস্বীকার করবে?",
          "numberInSurah": 23,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4925,
          "text": "দরিয়ায় বিচরণশীল পর্বতদৃশ্য জাহাজসমূহ তাঁরই (নিয়ন্ত্রনাধীন)",
          "numberInSurah": 24,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4926,
          "text": "অতএব, তোমরা উভয়ে তোমাদের পালনকর্তার কোন কোন অবদানকে অস্বীকার করবে?",
          "numberInSurah": 25,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 466,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4927,
          "text": "ভূপৃষ্টের সবকিছুই ধ্বংসশীল।",
          "numberInSurah": 26,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 467,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4928,
          "text": "একমাত্র আপনার মহিমায় ও মহানুভব পালনকর্তার সত্তা ছাড়া।",
          "numberInSurah": 27,
          "juz": 27,
          "manzil": 7,
          "page": 532,
          "ruku": 467,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
