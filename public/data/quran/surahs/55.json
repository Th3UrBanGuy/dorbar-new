          "page": 533,
          "ruku": 468,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
          "number": 4949,
          "text": "উভয় উদ্যানই ঘন শাখা-পল্লববিশিষ্ট।",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 533,
          "ruku": 468,
          "hizbQuarter": 213,
          "sajda": false
        },
        {
