  "data": [
    {
      "number": 51,
      "name": "سُورَةُ الذَّارِيَاتِ",
      "englishName": "Adh-Dhaariyat",
      "englishNameTranslation": "The Winnowing Winds",
      "revelationType": "Meccan",
      "numberOfAyahs": 60,
      "ayahs": [
        {
          "number": 4676,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلذَّٰرِيَٰتِ ذَرْوًۭا",
          "numberInSurah": 1,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4677,
          "text": "فَٱلْحَٰمِلَٰتِ وِقْرًۭا",
          "numberInSurah": 2,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4678,
          "text": "فَٱلْجَٰرِيَٰتِ يُسْرًۭا",
          "numberInSurah": 3,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4679,
          "text": "فَٱلْمُقَسِّمَٰتِ أَمْرًا",
          "numberInSurah": 4,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4680,
          "text": "إِنَّمَا تُوعَدُونَ لَصَادِقٌۭ",
          "numberInSurah": 5,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4681,
          "text": "وَإِنَّ ٱلدِّينَ لَوَٰقِعٌۭ",
          "numberInSurah": 6,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4682,
          "text": "وَٱلسَّمَآءِ ذَاتِ ٱلْحُبُكِ",
          "numberInSurah": 7,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4683,
          "text": "إِنَّكُمْ لَفِى قَوْلٍۢ مُّخْتَلِفٍۢ",
          "numberInSurah": 8,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4684,
          "text": "يُؤْفَكُ عَنْهُ مَنْ أُفِكَ",
          "numberInSurah": 9,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4685,
          "text": "قُتِلَ ٱلْخَرَّٰصُونَ",
          "numberInSurah": 10,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4686,
          "text": "ٱلَّذِينَ هُمْ فِى غَمْرَةٍۢ سَاهُونَ",
          "numberInSurah": 11,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4687,
          "text": "يَسْـَٔلُونَ أَيَّانَ يَوْمُ ٱلدِّينِ",
          "numberInSurah": 12,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4688,
          "text": "يَوْمَ هُمْ عَلَى ٱلنَّارِ يُفْتَنُونَ",
          "numberInSurah": 13,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4689,
          "text": "ذُوقُوا۟ فِتْنَتَكُمْ هَٰذَا ٱلَّذِى كُنتُم بِهِۦ تَسْتَعْجِلُونَ",
          "numberInSurah": 14,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4690,
          "text": "إِنَّ ٱلْمُتَّقِينَ فِى جَنَّٰتٍۢ وَعُيُونٍ",
          "numberInSurah": 15,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4691,
          "text": "ءَاخِذِينَ مَآ ءَاتَىٰهُمْ رَبُّهُمْ ۚ إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُحْسِنِينَ",
          "numberInSurah": 16,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4692,
          "text": "كَانُوا۟ قَلِيلًۭا مِّنَ ٱلَّيْلِ مَا يَهْجَعُونَ",
          "numberInSurah": 17,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4693,
          "text": "وَبِٱلْأَسْحَارِ هُمْ يَسْتَغْفِرُونَ",
          "numberInSurah": 18,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4694,
          "text": "وَفِىٓ أَمْوَٰلِهِمْ حَقٌّۭ لِّلسَّآئِلِ وَٱلْمَحْرُومِ",
          "numberInSurah": 19,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4695,
          "text": "وَفِى ٱلْأَرْضِ ءَايَٰتٌۭ لِّلْمُوقِنِينَ",
          "numberInSurah": 20,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4696,
          "text": "وَفِىٓ أَنفُسِكُمْ ۚ أَفَلَا تُبْصِرُونَ",
          "numberInSurah": 21,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4697,
          "text": "وَفِى ٱلسَّمَآءِ رِزْقُكُمْ وَمَا تُوعَدُونَ",
          "numberInSurah": 22,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4698,
          "text": "فَوَرَبِّ ٱلسَّمَآءِ وَٱلْأَرْضِ إِنَّهُۥ لَحَقٌّۭ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَ",
          "numberInSurah": 23,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4699,
          "text": "هَلْ أَتَىٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ ٱلْمُكْرَمِينَ",
          "numberInSurah": 24,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4700,
          "text": "إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَٰمًۭا ۖ قَالَ سَلَٰمٌۭ قَوْمٌۭ مُّنكَرُونَ",
          "numberInSurah": 25,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4701,
          "text": "فَرَاغَ إِلَىٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٍۢ سَمِينٍۢ",
          "numberInSurah": 26,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4702,
          "text": "فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَأْكُلُونَ",
          "numberInSurah": 27,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4703,
          "text": "فَأَوْجَسَ مِنْهُمْ خِيفَةًۭ ۖ قَالُوا۟ لَا تَخَفْ ۖ وَبَشَّرُوهُ بِغُلَٰمٍ عَلِيمٍۢ",
          "numberInSurah": 28,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4704,
          "text": "فَأَقْبَلَتِ ٱمْرَأَتُهُۥ فِى صَرَّةٍۢ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٌۭ",
          "numberInSurah": 29,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4705,
          "text": "قَالُوا۟ كَذَٰلِكِ قَالَ رَبُّكِ ۖ إِنَّهُۥ هُوَ ٱلْحَكِيمُ ٱلْعَلِيمُ",
          "numberInSurah": 30,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4706,
          "text": "۞ قَالَ فَمَا خَطْبُكُمْ أَيُّهَا ٱلْمُرْسَلُونَ",
          "numberInSurah": 31,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4707,
          "text": "قَالُوٓا۟ إِنَّآ أُرْسِلْنَآ إِلَىٰ قَوْمٍۢ مُّجْرِمِينَ",
          "numberInSurah": 32,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4708,
          "text": "لِنُرْسِلَ عَلَيْهِمْ حِجَارَةًۭ مِّن طِينٍۢ",
          "numberInSurah": 33,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4709,
          "text": "مُّسَوَّمَةً عِندَ رَبِّكَ لِلْمُسْرِفِينَ",
          "numberInSurah": 34,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4710,
          "text": "فَأَخْرَجْنَا مَن كَانَ فِيهَا مِنَ ٱلْمُؤْمِنِينَ",
          "numberInSurah": 35,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4711,
          "text": "فَمَا وَجَدْنَا فِيهَا غَيْرَ بَيْتٍۢ مِّنَ ٱلْمُسْلِمِينَ",
          "numberInSurah": 36,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4712,
          "text": "وَتَرَكْنَا فِيهَآ ءَايَةًۭ لِّلَّذِينَ يَخَافُونَ ٱلْعَذَابَ ٱلْأَلِيمَ",
          "numberInSurah": 37,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4713,
          "text": "وَفِى مُوسَىٰٓ إِذْ أَرْسَلْنَٰهُ إِلَىٰ فِرْعَوْنَ بِسُلْطَٰنٍۢ مُّبِينٍۢ",
          "numberInSurah": 38,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4714,
          "text": "فَتَوَلَّىٰ بِرُكْنِهِۦ وَقَالَ سَٰحِرٌ أَوْ مَجْنُونٌۭ",
          "numberInSurah": 39,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4715,
          "text": "فَأَخَذْنَٰهُ وَجُنُودَهُۥ فَنَبَذْنَٰهُمْ فِى ٱلْيَمِّ وَهُوَ مُلِيمٌۭ",
          "numberInSurah": 40,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4716,
          "text": "وَفِى عَادٍ إِذْ أَرْسَلْنَا عَلَيْهِمُ ٱلرِّيحَ ٱلْعَقِيمَ",
          "numberInSurah": 41,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4717,
          "text": "مَا تَذَرُ مِن شَىْءٍ أَتَتْ عَلَيْهِ إِلَّا جَعَلَتْهُ كَٱلرَّمِيمِ",
          "numberInSurah": 42,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4718,
          "text": "وَفِى ثَمُودَ إِذْ قِيلَ لَهُمْ تَمَتَّعُوا۟ حَتَّىٰ حِينٍۢ",
          "numberInSurah": 43,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4719,
          "text": "فَعَتَوْا۟ عَنْ أَمْرِ رَبِّهِمْ فَأَخَذَتْهُمُ ٱلصَّٰعِقَةُ وَهُمْ يَنظُرُونَ",
          "numberInSurah": 44,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4720,
          "text": "فَمَا ٱسْتَطَٰعُوا۟ مِن قِيَامٍۢ وَمَا كَانُوا۟ مُنتَصِرِينَ",
          "numberInSurah": 45,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4721,
          "text": "وَقَوْمَ نُوحٍۢ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ قَوْمًۭا فَٰسِقِينَ",
          "numberInSurah": 46,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4722,
          "text": "وَٱلسَّمَآءَ بَنَيْنَٰهَا بِأَيْي۟دٍۢ وَإِنَّا لَمُوسِعُونَ",
          "numberInSurah": 47,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4723,
          "text": "وَٱلْأَرْضَ فَرَشْنَٰهَا فَنِعْمَ ٱلْمَٰهِدُونَ",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4724,
          "text": "وَمِن كُلِّ شَىْءٍ خَلَقْنَا زَوْجَيْنِ لَعَلَّكُمْ تَذَكَّرُونَ",
          "numberInSurah": 49,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4725,
          "text": "فَفِرُّوٓا۟ إِلَى ٱللَّهِ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌۭ مُّبِينٌۭ",
          "numberInSurah": 50,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4726,
          "text": "وَلَا تَجْعَلُوا۟ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ ۖ إِنِّى لَكُم مِّنْهُ نَذِيرٌۭ مُّبِينٌۭ",
          "numberInSurah": 51,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4727,
          "text": "كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوْ مَجْنُونٌ",
          "numberInSurah": 52,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4728,
          "text": "أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌۭ طَاغُونَ",
          "numberInSurah": 53,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4729,
          "text": "فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍۢ",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4730,
          "text": "وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ",
          "numberInSurah": 55,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4731,
          "text": "وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ",
          "numberInSurah": 56,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4732,
          "text": "مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍۢ وَمَآ أُرِيدُ أَن يُطْعِمُونِ",
          "numberInSurah": 57,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4733,
          "text": "إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلْقُوَّةِ ٱلْمَتِينُ",
          "numberInSurah": 58,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4734,
          "text": "فَإِنَّ لِلَّذِينَ ظَلَمُوا۟ ذَنُوبًۭا مِّثْلَ ذَنُوبِ أَصْحَٰبِهِمْ فَلَا يَسْتَعْجِلُونِ",
          "numberInSurah": 59,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4735,
          "text": "فَوَيْلٌۭ لِّلَّذِينَ كَفَرُوا۟ مِن يَوْمِهِمُ ٱلَّذِى يُوعَدُونَ",
          "numberInSurah": 60,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 51,
      "name": "سُورَةُ الذَّارِيَاتِ",
      "englishName": "Adh-Dhaariyat",
      "englishNameTranslation": "The Winnowing Winds",
      "revelationType": "Meccan",
      "numberOfAyahs": 60,
      "ayahs": [
        {
          "number": 4676,
          "text": "কসম ঝঞ্ঝাবায়ুর।",
          "numberInSurah": 1,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4677,
          "text": "অতঃপর বোঝা বহনকারী মেঘের।",
          "numberInSurah": 2,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4678,
          "text": "অতঃপর মৃদু চলমান জলযানের,",
          "numberInSurah": 3,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4679,
          "text": "অতঃপর কর্ম বন্টনকারী ফেরেশতাগণের,",
          "numberInSurah": 4,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4680,
          "text": "তোমাদের প্রদত্ত ওয়াদা অবশ্যই সত্য।",
          "numberInSurah": 5,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4681,
          "text": "ইনসাফ অবশ্যম্ভাবী।",
          "numberInSurah": 6,
          "juz": 26,
          "manzil": 7,
          "page": 520,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4682,
          "text": "পথবিশিষ্ট আকাশের কসম,",
          "numberInSurah": 7,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4683,
          "text": "তোমরা তো বিরোধপূর্ণ কথা বলছ।",
          "numberInSurah": 8,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4684,
          "text": "যে ভ্রষ্ট, সেই এ থেকে মুখ ফিরায়,",
          "numberInSurah": 9,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4685,
          "text": "অনুমানকারীরা ধ্বংস হোক,",
          "numberInSurah": 10,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4686,
          "text": "যারা উদাসীন, ভ্রান্ত।",
          "numberInSurah": 11,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4687,
          "text": "তারা জিজ্ঞাসা করে, কেয়ামত কবে হবে?",
          "numberInSurah": 12,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4688,
          "text": "যেদিন তারা অগ্নিতে পতিত হবে,",
          "numberInSurah": 13,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4689,
          "text": "তোমরা তোমাদের শাস্তি আস্বাদন কর। তোমরা একেই ত্বরান্বিত করতে চেয়েছিল।",
          "numberInSurah": 14,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4690,
          "text": "খোদাভীরুরা জান্নাতে ও প্রস্রবণে থাকবে।",
          "numberInSurah": 15,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4691,
          "text": "এমতাবস্থায় যে, তারা গ্রহণ করবে যা তাদের পালনকর্তা তাদেরকে দেবেন। নিশ্চয় ইতিপূর্বে তারা ছিল সৎকর্মপরায়ণ,",
          "numberInSurah": 16,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4692,
          "text": "তারা রাত্রির সামান্য অংশেই নিদ্রা যেত,",
          "numberInSurah": 17,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4693,
          "text": "রাতের শেষ প্রহরে তারা ক্ষমাপ্রার্থনা করত,",
          "numberInSurah": 18,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4694,
          "text": "এবং তাদের ধন-সম্পদে প্রার্থী ও বঞ্চিতের হক ছিল।",
          "numberInSurah": 19,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4695,
          "text": "বিশ্বাসকারীদের জন্যে পৃথিবীতে নিদর্শনাবলী রয়েছে,",
          "numberInSurah": 20,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4696,
          "text": "এবং তোমাদের নিজেদের মধ্যেও, তোমরা কি অনুধাবন করবে না?",
          "numberInSurah": 21,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4697,
          "text": "আকাশে রয়েছে তোমাদের রিযিক ও প্রতিশ্রুত সবকিছু।",
          "numberInSurah": 22,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4698,
          "text": "নভোমন্ডল ও ভূমন্ডলের পালনকর্তার কসম, তোমাদের কথাবার্তার মতই এটা সত্য।",
          "numberInSurah": 23,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 455,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4699,
          "text": "আপনার কাছে ইব্রাহীমের সম্মানিত মেহমানদের বৃত্তান্ত এসেছে কি?",
          "numberInSurah": 24,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4700,
          "text": "যখন তারা তাঁর কাছে উপস্থিত হয়ে বললঃ সালাম, তখন সে বললঃ সালাম। এরা তো অপরিচিত লোক।",
          "numberInSurah": 25,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4701,
          "text": "অতঃপর সে গ্রহে গেল এবং একটি ঘৃতেপক্ক মোটা গোবৎস নিয়ে হাযির হল।",
          "numberInSurah": 26,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4702,
          "text": "সে গোবৎসটি তাদের সামনে রেখে বললঃ তোমরা আহার করছ না কেন?",
          "numberInSurah": 27,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4703,
          "text": "অতঃপর তাদের সম্পর্কে সে মনে মনে ভীত হলঃ তারা বললঃ ভীত হবেন না। তারা তাঁকে একট জ্ঞানীগুণী পুত্র সন্তানের সুসংবাদ দিল।",
          "numberInSurah": 28,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4704,
          "text": "অতঃপর তাঁর স্ত্রী চীৎকার করতে করতে সামনে এল এবং মুখ চাপড়িয়ে বললঃ আমি তো বৃদ্ধা, বন্ধ্যা।",
          "numberInSurah": 29,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4705,
          "text": "তারা বললঃ তোমার পালনকর্তা এরূপই বলেছেন। নিশ্চয় তিনি প্রজ্ঞাময়, সর্বজ্ঞ।",
          "numberInSurah": 30,
          "juz": 26,
          "manzil": 7,
          "page": 521,
          "ruku": 456,
          "hizbQuarter": 208,
          "sajda": false
        },
        {
          "number": 4706,
          "text": "ইব্রাহীম বললঃ হে প্রেরিত ফেরেশতাগণ, তোমাদের উদ্দেশ্য কি?",
          "numberInSurah": 31,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4707,
          "text": "তারা বললঃ আমরা এক অপরাধী সম্প্রদায়ের প্রতি প্রেরিত হয়েছি,",
          "numberInSurah": 32,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4708,
          "text": "যাতে তাদের উপর মাটির ঢিলা নিক্ষেপ করি।",
          "numberInSurah": 33,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4709,
          "text": "যা সীমাতিক্রমকারীদের জন্যে আপনার পালনকর্তার কাছে চিহিߦ#2468; আছে।",
          "numberInSurah": 34,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4710,
          "text": "অতঃপর সেখানে যারা ঈমানদার ছিল, আমি তাদেরকে উদ্ধার করলাম।",
          "numberInSurah": 35,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4711,
          "text": "এবং সেখানে একটি গৃহ ব্যতীত কোন মুসলমান আমি পাইনি।",
          "numberInSurah": 36,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4712,
          "text": "যারা যন্ত্রণাদায়ক শাস্তিকে ভয় করে, আমি তাদের জন্যে সেখানে একটি নিদর্শন রেখেছি।",
          "numberInSurah": 37,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4713,
          "text": "এবং নিদর্শন রয়েছে মূসার বৃত্তান্তে; যখন আমি তাকে সুস্পষ্ট প্রমাণসহ ফেরাউনের কাছে প্রেরণ করেছিলাম।",
          "numberInSurah": 38,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4714,
          "text": "অতঃপর সে শক্তিবলে মুখ ফিরিয়ে নিল এবং বললঃ সে হয় যাদুকর, না হয় পাগল।",
          "numberInSurah": 39,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4715,
          "text": "অতঃপর আমি তাকে ও তার সেনাবাহিনীকে পাকড়াও করলাম এবং তাদেরকে সমুদ্রে নিক্ষেপ করলাম। সে ছিল অভিযুক্ত।",
          "numberInSurah": 40,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4716,
          "text": "এবং নিদর্শন রয়েছে তাদের কাহিনীতে; যখন আমি তাদের উপর প্রেরণ করেছিলাম অশুভ বায়ু।",
          "numberInSurah": 41,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4717,
          "text": "এই বায়ু যার উপর দিয়ে প্রবাহিত হয়েছিলঃ তাকেই চুর্ণ-বিচুর্ণ করে দিয়েছিল।",
          "numberInSurah": 42,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4718,
          "text": "আরও নিদর্শন রয়েছে সামূদের ঘটনায়; যখন তাদেরকে বলা হয়েছিল, কিছুকাল মজা লুটে নাও।",
          "numberInSurah": 43,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4719,
          "text": "অতঃপর তারা তাদের পালনকর্তার আদেশ অমান্য করল এবং তাদের প্রতি বজ্রঘাত হল এমতাবস্থায় যে, তারা তা দেখেছিল।",
          "numberInSurah": 44,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4720,
          "text": "অতঃপর তারা দাঁড়াতে সক্ষম হল না এবং কোন প্রতিকারও করতে পারল না।",
          "numberInSurah": 45,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4721,
          "text": "আমি ইতিপূর্বে নূহের সম্প্রদায়কে ধ্বংস করেছি। নিশ্চিতই তারা ছিল পাপাচারী সম্প্রদায়।",
          "numberInSurah": 46,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 456,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4722,
          "text": "আমি স্বীয় ক্ষমতাবলে আকাশ নির্মাণ করেছি এবং আমি অবশ্যই ব্যাপক ক্ষমতাশালী।",
          "numberInSurah": 47,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4723,
          "text": "আমি ভূমিকে বিছিয়েছি। আমি কত সুন্দরভাবেই না বিছাতে সক্ষম।",
          "numberInSurah": 48,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4724,
          "text": "আমি প্রত্যেক বস্তু জোড়ায় জোড়ায় সৃষ্টি করেছি, যাতে তোমরা হৃদয়ঙ্গম কর।",
          "numberInSurah": 49,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4725,
          "text": "অতএব, আল্লাহর দিকে ধাবিত হও। আমি তাঁর তরফ থেকে তোমাদের জন্যে সুস্পষ্ট সতর্ককারী।",
          "numberInSurah": 50,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4726,
          "text": "তোমরা আল্লাহর সাথে কোন উপাস্য সাব্যস্ত করো না। আমি তাঁর পক্ষ থেকে তোমাদের জন্য সুস্পষ্ট সতর্ককারী।",
          "numberInSurah": 51,
          "juz": 27,
          "manzil": 7,
          "page": 522,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4727,
          "text": "এমনিভাবে, তাদের পূর্ববর্তীদের কাছে যখনই কোন রসূল আগমন করেছে, তারা বলছেঃ যাদুকর, না হয় উম্মাদ।",
          "numberInSurah": 52,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4728,
          "text": "তারা কি একে অপরকে এই উপদেশই দিয়ে গেছে? বস্তুতঃ ওরা দুষ্ট সম্প্রদায়।",
          "numberInSurah": 53,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4729,
          "text": "অতএব, আপনি ওদের থেকে মুখ ফিরিয়ে নিন। এতে আপনি অপরাধী হবেন না।",
          "numberInSurah": 54,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4730,
          "text": "এবং বোঝাতে থাকুন; কেননা, বোঝানো মুমিনদের উপকারে আসবে।",
          "numberInSurah": 55,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4731,
          "text": "আমার এবাদত করার জন্যই আমি মানব ও জিন জাতি সৃষ্টি করেছি।",
          "numberInSurah": 56,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4732,
          "text": "আমি তাদের কাছে জীবিকা চাই না এবং এটাও চাই না যে, তারা আমাকে আহার্য যোগাবে।",
          "numberInSurah": 57,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4733,
          "text": "আল্লাহ তা’আলাই তো জীবিকাদাতা শক্তির আধার, পরাক্রান্ত।",
          "numberInSurah": 58,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4734,
          "text": "অতএব, এই যালেমদের প্রাপ্য তাই, যা ওদের অতীত সহচরদের প্রাপ্য ছিল। কাজেই ওরা যেন আমার কাছে তা তাড়াতাড়ি না চায়।",
          "numberInSurah": 59,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        },
        {
          "number": 4735,
          "text": "অতএব, কাফেরদের জন্যে দুর্ভোগ সেই দিনের, যেদিনের প্রতিশ্রুতি ওদেরকে দেয়া হয়েছে।",
          "numberInSurah": 60,
          "juz": 27,
          "manzil": 7,
          "page": 523,
          "ruku": 457,
          "hizbQuarter": 209,
          "sajda": false
        }
      ],
