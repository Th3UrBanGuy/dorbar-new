  "data": [
    {
      "number": 104,
      "name": "سُورَةُ الهُمَزَةِ",
      "englishName": "Al-Humaza",
      "englishNameTranslation": "The Traducer",
      "revelationType": "Meccan",
      "numberOfAyahs": 9,
      "ayahs": [
        {
          "number": 6180,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6181,
          "text": "ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6182,
          "text": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6183,
          "text": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6184,
          "text": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6185,
          "text": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6186,
          "text": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6187,
          "text": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6188,
          "text": "فِى عَمَدٍۢ مُّمَدَّدَةٍۭ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 104,
      "name": "سُورَةُ الهُمَزَةِ",
      "englishName": "Al-Humaza",
      "englishNameTranslation": "The Traducer",
      "revelationType": "Meccan",
      "numberOfAyahs": 9,
      "ayahs": [
        {
          "number": 6180,
          "text": "প্রত্যেক পশ্চাতে ও সম্মুখে পরনিন্দাকারীর দুর্ভোগ,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6181,
          "text": "যে অর্থ সঞ্চিত করে ও গণনা করে",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6182,
          "text": "সে মনে করে যে, তার অর্থ চিরকাল তার সাথে থাকবে!",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6183,
          "text": "কখনও না, সে অবশ্যই নিক্ষিপ্ত হবে পিষ্টকারীর মধ্যে।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6184,
          "text": "আপনি কি জানেন, পিষ্টকারী কি?",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6185,
          "text": "এটা আল্লাহর প্রজ্জ্বলিত অগ্নি,",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6186,
          "text": "যা হৃদয় পর্যন্ত পৌছবে।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6187,
          "text": "এতে তাদেরকে বেঁধে দেয়া হবে,",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6188,
          "text": "লম্বা লম্বা খুঁটিতে।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 601,
          "ruku": 546,
          "hizbQuarter": 240,
          "sajda": false
        }
      ],
