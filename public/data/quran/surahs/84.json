  "data": [
    {
      "number": 84,
      "name": "سُورَةُ الانشِقَاقِ",
      "englishName": "Al-Inshiqaaq",
      "englishNameTranslation": "The Splitting Open",
      "revelationType": "Meccan",
      "numberOfAyahs": 25,
      "ayahs": [
        {
          "number": 5885,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتْ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5886,
          "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5887,
          "text": "وَإِذَا ٱلْأَرْضُ مُدَّتْ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5888,
          "text": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5889,
          "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5890,
          "text": "يَٰٓأَيُّهَا ٱلْإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدْحًۭا فَمُلَٰقِيهِ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5891,
          "text": "فَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ بِيَمِينِهِۦ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5892,
          "text": "فَسَوْفَ يُحَاسَبُ حِسَابًۭا يَسِيرًۭا",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5893,
          "text": "وَيَنقَلِبُ إِلَىٰٓ أَهْلِهِۦ مَسْرُورًۭا",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5894,
          "text": "وَأَمَّا مَنْ أُوتِىَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5895,
          "text": "فَسَوْفَ يَدْعُوا۟ ثُبُورًۭا",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5896,
          "text": "وَيَصْلَىٰ سَعِيرًا",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5897,
          "text": "إِنَّهُۥ كَانَ فِىٓ أَهْلِهِۦ مَسْرُورًا",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5898,
          "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5899,
          "text": "بَلَىٰٓ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرًۭا",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5900,
          "text": "فَلَآ أُقْسِمُ بِٱلشَّفَقِ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5901,
          "text": "وَٱلَّيْلِ وَمَا وَسَقَ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5902,
          "text": "وَٱلْقَمَرِ إِذَا ٱتَّسَقَ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5903,
          "text": "لَتَرْكَبُنَّ طَبَقًا عَن طَبَقٍۢ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5904,
          "text": "فَمَا لَهُمْ لَا يُؤْمِنُونَ",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5905,
          "text": "وَإِذَا قُرِئَ عَلَيْهِمُ ٱلْقُرْءَانُ لَا يَسْجُدُونَ ۩",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": {
            "id": 14,
            "recommended": true,
            "obligatory": false
          }
        },
        {
          "number": 5906,
          "text": "بَلِ ٱلَّذِينَ كَفَرُوا۟ يُكَذِّبُونَ",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5907,
          "text": "وَٱللَّهُ أَعْلَمُ بِمَا يُوعُونَ",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5908,
          "text": "فَبَشِّرْهُم بِعَذَابٍ أَلِيمٍ",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5909,
          "text": "إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّٰلِحَٰتِ لَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍۭ",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 84,
      "name": "سُورَةُ الانشِقَاقِ",
      "englishName": "Al-Inshiqaaq",
      "englishNameTranslation": "The Splitting Open",
      "revelationType": "Meccan",
      "numberOfAyahs": 25,
      "ayahs": [
        {
          "number": 5885,
          "text": "যখন আকাশ বিদীর্ণ হবে,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5886,
          "text": "ও তার পালনকর্তার আদেশ পালন করবে এবং আকাশ এরই উপযুক্ত",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5887,
          "text": "এবং যখন পৃথিবীকে সম্প্রসারিত করা হবে।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5888,
          "text": "এবং পৃথিবী তার গর্ভস্থিত সবকিছু বাইরে নিক্ষেপ করবে ও শুন্যগর্ভ হয়ে যাবে।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5889,
          "text": "এবং তার পালনকর্তার আদেশ পালন করবে এবং পৃথিবী এরই উপযুক্ত।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5890,
          "text": "হে মানুষ, তোমাকে তোমরা পালনকর্তা পর্যন্ত পৌছতে কষ্ট স্বীকার করতে হবে, অতঃপর তার সাক্ষাৎ ঘটবে।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5891,
          "text": "যাকে তার আমলনামা ডান হাতে দেয়া হবে",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5892,
          "text": "তার হিসাব-নিকাশ সহজে হয়ে যাবে",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5893,
          "text": "এবং সে তার পরিবার-পরিজনের কাছে হৃষ্টচিত্তে ফিরে যাবে",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5894,
          "text": "এবং যাকে তার আমলনামা পিঠের পশ্চাদ্দিক থেকে দেয়া, হবে,",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5895,
          "text": "সে মৃত্যুকে আহবান করবে,",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5896,
          "text": "এবং জাহান্নামে প্রবেশ করবে।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5897,
          "text": "সে তার পরিবার-পরিজনের মধ্যে আনন্দিত ছিল।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5898,
          "text": "সে মনে করত যে, সে কখনও ফিরে যাবে না।",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5899,
          "text": "কেন যাবে না, তার পালনকর্তা তো তাকে দেখতেন।",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5900,
          "text": "আমি শপথ করি সন্ধ্যাকালীন লাল আভার",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5901,
          "text": "এবং রাত্রির, এবং তাতে যার সমাবেশ ঘটে",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5902,
          "text": "এবং চন্দ্রের, যখন তা পূর্ণরূপ লাভ করে,",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5903,
          "text": "নিশ্চয় তোমরা এক সিঁড়ি থেকে আরেক সিঁড়িতে আরোহণ করবে।",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5904,
          "text": "অতএব, তাদের কি হল যে, তারা ঈমান আনে না?",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5905,
          "text": "যখন তাদের কাছে কোরআন পাঠ করা হয়, তখন সেজদা করে না।",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": {
            "id": 14,
            "recommended": true,
            "obligatory": false
          }
        },
        {
          "number": 5906,
          "text": "বরং কাফেররা এর প্রতি মিথ্যারোপ করে।",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5907,
          "text": "তারা যা সংরক্ষণ করে, আল্লাহ তা জানেন।",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5908,
          "text": "অতএব, তাদেরকে যন্ত্রণাদায়ক শাস্তির সুসংবাদ দিন।",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5909,
          "text": "কিন্তু যারা বিশ্বাস স্থাপন করে ও সৎকর্ম করে, তাদের জন্য রয়েছে অফুরন্ত পুরস্কার।",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 589,
          "ruku": 526,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}