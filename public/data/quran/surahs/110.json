          "ruku": 552,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6215,
          "text": "এবং আপনি মানুষকে দলে দলে আল্লাহর দ্বীনে প্রবেশ করতে দেখবেন,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 603,
          "ruku": 552,
          "hizbQuarter": 240,
          "sajda": false
        },
        {
          "number": 6216,
          "text": "তখন আপনি আপনার পালনকর্তার পবিত্রতা বর্ণনা করুন এবং তাঁর কাছে ক্ষমা প্রার্থনা করুন। নিশ্চয় তিনি ক্ষমাকারী।",
          "numberInSurah": 3,
          "juz": 30,
