  "data": [
    {
      "number": 71,
      "name": "سُورَةُ نُوحٍ",
      "englishName": "Nooh",
      "englishNameTranslation": "Noah",
      "revelationType": "Meccan",
      "numberOfAyahs": 28,
      "ayahs": [
        {
          "number": 5420,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِنَّآ أَرْسَلْنَا نُوحًا إِلَىٰ قَوْمِهِۦٓ أَنْ أَنذِرْ قَوْمَكَ مِن قَبْلِ أَن يَأْتِيَهُمْ عَذَابٌ أَلِيمٌۭ",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5421,
          "text": "قَالَ يَٰقَوْمِ إِنِّى لَكُمْ نَذِيرٌۭ مُّبِينٌ",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5422,
          "text": "أَنِ ٱعْبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِيعُونِ",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5423,
          "text": "يَغْفِرْ لَكُم مِّن ذُنُوبِكُمْ وَيُؤَخِّرْكُمْ إِلَىٰٓ أَجَلٍۢ مُّسَمًّى ۚ إِنَّ أَجَلَ ٱللَّهِ إِذَا جَآءَ لَا يُؤَخَّرُ ۖ لَوْ كُنتُمْ تَعْلَمُونَ",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5424,
          "text": "قَالَ رَبِّ إِنِّى دَعَوْتُ قَوْمِى لَيْلًۭا وَنَهَارًۭا",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5425,
          "text": "فَلَمْ يَزِدْهُمْ دُعَآءِىٓ إِلَّا فِرَارًۭا",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5426,
          "text": "وَإِنِّى كُلَّمَا دَعَوْتُهُمْ لِتَغْفِرَ لَهُمْ جَعَلُوٓا۟ أَصَٰبِعَهُمْ فِىٓ ءَاذَانِهِمْ وَٱسْتَغْشَوْا۟ ثِيَابَهُمْ وَأَصَرُّوا۟ وَٱسْتَكْبَرُوا۟ ٱسْتِكْبَارًۭا",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5427,
          "text": "ثُمَّ إِنِّى دَعَوْتُهُمْ جِهَارًۭا",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5428,
          "text": "ثُمَّ إِنِّىٓ أَعْلَنتُ لَهُمْ وَأَسْرَرْتُ لَهُمْ إِسْرَارًۭا",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5429,
          "text": "فَقُلْتُ ٱسْتَغْفِرُوا۟ رَبَّكُمْ إِنَّهُۥ كَانَ غَفَّارًۭا",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5430,
          "text": "يُرْسِلِ ٱلسَّمَآءَ عَلَيْكُم مِّدْرَارًۭا",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5431,
          "text": "وَيُمْدِدْكُم بِأَمْوَٰلٍۢ وَبَنِينَ وَيَجْعَل لَّكُمْ جَنَّٰتٍۢ وَيَجْعَل لَّكُمْ أَنْهَٰرًۭا",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5432,
          "text": "مَّا لَكُمْ لَا تَرْجُونَ لِلَّهِ وَقَارًۭا",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5433,
          "text": "وَقَدْ خَلَقَكُمْ أَطْوَارًا",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5434,
          "text": "أَلَمْ تَرَوْا۟ كَيْفَ خَلَقَ ٱللَّهُ سَبْعَ سَمَٰوَٰتٍۢ طِبَاقًۭا",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5435,
          "text": "وَجَعَلَ ٱلْقَمَرَ فِيهِنَّ نُورًۭا وَجَعَلَ ٱلشَّمْسَ سِرَاجًۭا",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5436,
          "text": "وَٱللَّهُ أَنۢبَتَكُم مِّنَ ٱلْأَرْضِ نَبَاتًۭا",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5437,
          "text": "ثُمَّ يُعِيدُكُمْ فِيهَا وَيُخْرِجُكُمْ إِخْرَاجًۭا",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5438,
          "text": "وَٱللَّهُ جَعَلَ لَكُمُ ٱلْأَرْضَ بِسَاطًۭا",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5439,
          "text": "لِّتَسْلُكُوا۟ مِنْهَا سُبُلًۭا فِجَاجًۭا",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5440,
          "text": "قَالَ نُوحٌۭ رَّبِّ إِنَّهُمْ عَصَوْنِى وَٱتَّبَعُوا۟ مَن لَّمْ يَزِدْهُ مَالُهُۥ وَوَلَدُهُۥٓ إِلَّا خَسَارًۭا",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5441,
          "text": "وَمَكَرُوا۟ مَكْرًۭا كُبَّارًۭا",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5442,
          "text": "وَقَالُوا۟ لَا تَذَرُنَّ ءَالِهَتَكُمْ وَلَا تَذَرُنَّ وَدًّۭا وَلَا سُوَاعًۭا وَلَا يَغُوثَ وَيَعُوقَ وَنَسْرًۭا",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5443,
          "text": "وَقَدْ أَضَلُّوا۟ كَثِيرًۭا ۖ وَلَا تَزِدِ ٱلظَّٰلِمِينَ إِلَّا ضَلَٰلًۭا",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5444,
          "text": "مِّمَّا خَطِيٓـَٰٔتِهِمْ أُغْرِقُوا۟ فَأُدْخِلُوا۟ نَارًۭا فَلَمْ يَجِدُوا۟ لَهُم مِّن دُونِ ٱللَّهِ أَنصَارًۭا",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5445,
          "text": "وَقَالَ نُوحٌۭ رَّبِّ لَا تَذَرْ عَلَى ٱلْأَرْضِ مِنَ ٱلْكَٰفِرِينَ دَيَّارًا",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5446,
          "text": "إِنَّكَ إِن تَذَرْهُمْ يُضِلُّوا۟ عِبَادَكَ وَلَا يَلِدُوٓا۟ إِلَّا فَاجِرًۭا كَفَّارًۭا",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5447,
          "text": "رَّبِّ ٱغْفِرْ لِى وَلِوَٰلِدَىَّ وَلِمَن دَخَلَ بَيْتِىَ مُؤْمِنًۭا وَلِلْمُؤْمِنِينَ وَٱلْمُؤْمِنَٰتِ وَلَا تَزِدِ ٱلظَّٰلِمِينَ إِلَّا تَبَارًۢا",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 71,
      "name": "سُورَةُ نُوحٍ",
      "englishName": "Nooh",
      "englishNameTranslation": "Noah",
      "revelationType": "Meccan",
      "numberOfAyahs": 28,
      "ayahs": [
        {
          "number": 5420,
          "text": "আমি নূহকে প্রেরণ করেছিলাম তাঁর সম্প্রদায়ের প্রতি একথা বলেঃ তুমি তোমার সম্প্রদায়কে সতর্ক কর, তাদের প্রতি মর্মন্তদ শাস্তি আসার আগে।",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5421,
          "text": "সে বলল, হে আমার সম্প্রদায়! আমি তোমাদের জন্যে স্পষ্ট সতর্ককারী।",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5422,
          "text": "এ বিষয়ে যে, তোমরা আল্লাহ তা’আলার এবাদত কর, তাঁকে ভয় কর এবং আমার আনুগত্য কর।",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5423,
          "text": "আল্লাহ তা’আলা তোমাদের পাপসমূহ ক্ষমা করবেন এবং নির্দিষ্ট সময় পর্যন্ত অবকাশ দিবেন। নিশ্চয় আল্লাহ তা’আলার নির্দিষ্টকাল যখন হবে, তখন অবকাশ দেয়া হবে না, যদি তোমরা তা জানতে!",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5424,
          "text": "সে বললঃ হে আমার পালনকর্তা! আমি আমার সম্প্রদায়কে দিবারাত্রি দাওয়াত দিয়েছি;",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5425,
          "text": "কিন্তু আমার দাওয়াত তাদের পলায়নকেই বৃদ্ধি করেছে।",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5426,
          "text": "আমি যতবারই তাদেরকে দাওয়াত দিয়েছি, যাতে আপনি তাদেরকে ক্ষমা করেন, ততবারই তারা কানে অঙ্গুলি দিয়েছে, মুখমন্ডল বস্ত্রাবৃত করেছে, জেদ করেছে এবং খুব ঔদ্ধত্য প্রদর্শন করেছে।",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5427,
          "text": "অতঃপর আমি তাদেরকে প্রকাশ্যে দাওয়াত দিয়েছি,",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5428,
          "text": "অতঃপর আমি ঘোষণা সহকারে প্রচার করেছি এবং গোপনে চুপিসারে বলেছি।",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5429,
          "text": "অতঃপর বলেছিঃ তোমরা তোমাদের পালনকর্তার ক্ষমা প্রার্থনা কর। তিনি অত্যন্ত ক্ষমাশীল।",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 570,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5430,
          "text": "তিনি তোমাদের উপর অজস্র বৃষ্টিধারা ছেড়ে দিবেন,",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5431,
          "text": "তোমাদের ধন-সম্পদ ও সন্তান-সন্ততি বাড়িয়ে দিবেন, তোমাদের জন্যে উদ্যান স্থাপন করবেন এবং তোমাদের জন্যে নদীনালা প্রবাহিত করবেন।",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5432,
          "text": "তোমাদের কি হল যে, তোমরা আল্লাহ তা’আলার শ্রেষ্টত্ব আশা করছ না।",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5433,
          "text": "অথচ তিনি তোমাদেরকে বিভিন্ন রকমে সৃষ্টি করেছেন।",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5434,
          "text": "তোমরা কি লক্ষ্য কর না যে, আল্লাহ কিভাবে সপ্ত আকাশ স্তরে স্তরে সৃষ্টি করেছেন।",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5435,
          "text": "এবং সেখানে চন্দ্রকে রেখেছেন আলোরূপে এবং সূর্যকে রেখেছেন প্রদীপরূপে।",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5436,
          "text": "আল্লাহ তা’আলা তোমাদেরকে মৃত্তিকা থেকে উদগত করেছেন।",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5437,
          "text": "অতঃপর তাতে ফিরিয়ে নিবেন এবং আবার পুনরুত্থিত করবেন।",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5438,
          "text": "আল্লাহ তা’আলা তোমাদের জন্যে ভূমিকে করেছেন বিছানা।",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5439,
          "text": "যাতে তোমরা চলাফেরা কর প্রশস্ত পথে।",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 504,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5440,
          "text": "নূহ বললঃ হে আমার পালনকর্তা, আমার সম্প্রদায় আমাকে অমান্য করেছে আর অনুসরণ করছে এমন লোককে, যার ধন-সম্পদ ও সন্তান-সন্ততি কেবল তার ক্ষতিই বৃদ্ধি করছে।",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5441,
          "text": "আর তারা ভয়ানক চক্রান্ত করছে।",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5442,
          "text": "তারা বলছেঃ তোমরা তোমাদের উপাস্যদেরকে ত্যাগ করো না এবং ত্যাগ করো না ওয়াদ, সূয়া, ইয়াগুছ, ইয়াউক ও নসরকে।",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5443,
          "text": "অথচ তারা অনেককে পথভ্রষ্ট করেছে। অতএব আপনি জালেমদের পথভ্রষ্টতাই বাড়িয়ে দিন।",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5444,
          "text": "তাদের গোনাহসমূহের দরুন তাদেরকে নিমজ্জিত করা হয়েছে, অতঃপর দাখিল করা হয়েছে জাহান্নামে। অতঃপর তারা আল্লাহ তা’আলা ব্যতীত কাউকে সাহায্যকারী পায়নি।",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5445,
          "text": "নূহ আরও বললঃ হে আমার পালনকর্তা, আপনি পৃথিবীতে কোন কাফের গৃহবাসীকে রেহাই দিবেন না।",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5446,
          "text": "যদি আপনি তাদেরকে রেহাই দেন, তবে তারা আপনার বান্দাদেরকে পথভ্রষ্ট করবে এবং জন্ম দিতে থাকবে কেবল পাপাচারী, কাফের।",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        },
        {
          "number": 5447,
          "text": "হে আমার পালনকর্তা! আপনি আমাকে, আমার পিতা-মাতাকে, যারা মুমিন হয়ে আমার গৃহে প্রবেশ করে-তাদেরকে এবং মুমিন পুরুষ ও মুমিন নারীদেরকে ক্ষমা করুন এবং যালেমদের কেবল ধ্বংসই বৃদ্ধি করুন।",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 571,
          "ruku": 505,
          "hizbQuarter": 228,
          "sajda": false
        }
      ],
