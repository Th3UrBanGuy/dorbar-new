  "data": [
    {
      "number": 86,
      "name": "سُورَةُ الطَّارِقِ",
      "englishName": "At-Taariq",
      "englishNameTranslation": "The Morning Star",
      "revelationType": "Meccan",
      "numberOfAyahs": 17,
      "ayahs": [
        {
          "number": 5932,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ وَٱلطَّارِقِ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5933,
          "text": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5934,
          "text": "ٱلنَّجْمُ ٱلثَّاقِبُ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5935,
          "text": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5936,
          "text": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5937,
          "text": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5938,
          "text": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5939,
          "text": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5940,
          "text": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5941,
          "text": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5942,
          "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5943,
          "text": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5944,
          "text": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5945,
          "text": "وَمَا هُوَ بِٱلْهَزْلِ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5946,
          "text": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5947,
          "text": "وَأَكِيدُ كَيْدًۭا",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5948,
          "text": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 86,
      "name": "سُورَةُ الطَّارِقِ",
      "englishName": "At-Taariq",
      "englishNameTranslation": "The Morning Star",
      "revelationType": "Meccan",
      "numberOfAyahs": 17,
      "ayahs": [
        {
          "number": 5932,
          "text": "শপথ আকাশের এবং রাত্রিতে আগমনকারীর।",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5933,
          "text": "আপনি জানেন, যে রাত্রিতে আসে সেটা কি?",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5934,
          "text": "সেটা এক উজ্জ্বল নক্ষত্র।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5935,
          "text": "প্রত্যেকের উপর একজন তত্ত্বাবধায়ক রয়েছে।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5936,
          "text": "অতএব, মানুষের দেখা উচিত কি বস্তু থেকে সে সৃজিত হয়েছে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5937,
          "text": "সে সৃজিত হয়েছে সবেগে স্খলিত পানি থেকে।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5938,
          "text": "এটা নির্গত হয় মেরুদন্ড ও বক্ষপাজরের মধ্য থেকে।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5939,
          "text": "নিশ্চয় তিনি তাকে ফিরিয়ে নিতে সক্ষম।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5940,
          "text": "যেদিন গোপন বিষয়াদি পরীক্ষিত হবে,",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5941,
          "text": "সেদিন তার কোন শক্তি থাকবে না এবং সাহায্যকারীও থাকবে না।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5942,
          "text": "শপথ চক্রশীল আকাশের",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5943,
          "text": "এবং বিদারনশীল পৃথিবীর",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5944,
          "text": "নিশ্চয় কোরআন সত্য-মিথ্যার ফয়সালা।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5945,
          "text": "এবং এটা উপহাস নয়।",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5946,
          "text": "তারা ভীষণ চক্রান্ত করে,",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5947,
          "text": "আর আমিও কৌশল করি।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        },
        {
          "number": 5948,
          "text": "অতএব, কাফেরদেরকে অবকাশ দিন, তাদেরকে অবকাশ দিন, কিছু দিনের জন্যে।",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 591,
          "ruku": 528,
          "hizbQuarter": 236,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
        "language": "bn",
        "name": "মুহিউদ্দীন খান",
        "englishName": "Muhiuddin Khan",
        "format": "text",
        "type": "translation",
        "direction": "ltr"
      }
    }
  ]
}