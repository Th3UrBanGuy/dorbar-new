    {
      "number": 99,
      "name": "سُورَةُ الزَّلۡزَلَةِ",
      "englishName": "Az-Zalzala",
      "englishNameTranslation": "The Earthquake",
      "revelationType": "Medinan",
      "numberOfAyahs": 8,
      "ayahs": [
        {
          "number": 6139,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6140,
          "text": "وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6141,
          "text": "وَقَالَ ٱلْإِنسَٰنُ مَا لَهَا",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6142,
          "text": "يَوْمَئِذٍۢ تُحَدِّثُ أَخْبَارَهَا",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6143,
          "text": "بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6144,
          "text": "يَوْمَئِذٍۢ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًۭا لِّيُرَوْا۟ أَعْمَٰلَهُمْ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6145,
          "text": "فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًۭا يَرَهُۥ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6146,
          "text": "وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍۢ شَرًّۭا يَرَهُۥ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 99,
      "name": "سُورَةُ الزَّلۡزَلَةِ",
      "englishName": "Az-Zalzala",
      "englishNameTranslation": "The Earthquake",
      "revelationType": "Medinan",
      "numberOfAyahs": 8,
      "ayahs": [
        {
          "number": 6139,
          "text": "যখন পৃথিবী তার কম্পনে প্রকম্পিত হবে,",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6140,
          "text": "যখন সে তার বোঝা বের করে দেবে।",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6141,
          "text": "এবং মানুষ বলবে, এর কি হল ?",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6142,
          "text": "সেদিন সে তার বৃত্তান্ত বর্ণনা করবে,",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6143,
          "text": "কারণ, আপনার পালনকর্তা তাকে আদেশ করবেন।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6144,
          "text": "সেদিন মানুষ বিভিন্ন দলে প্রকাশ পাবে, যাতে তাদেরকে তাদের কৃতকর্ম দেখানো হয়।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6145,
          "text": "অতঃপর কেউ অণু পরিমাণ সৎকর্ম করলে তা দেখতে পাবে",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        },
        {
          "number": 6146,
          "text": "এবং কেউ অণু পরিমাণ অসৎকর্ম করলে তাও দেখতে পাবে।",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 599,
          "ruku": 541,
          "hizbQuarter": 239,
          "sajda": false
        }
      ],
