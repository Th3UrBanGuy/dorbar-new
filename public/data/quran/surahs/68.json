  "data": [
    {
      "number": 68,
      "name": "سُورَةُ القَلَمِ",
      "englishName": "Al-Qalam",
      "englishNameTranslation": "The Pen",
      "revelationType": "Meccan",
      "numberOfAyahs": 52,
      "ayahs": [
        {
          "number": 5272,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ نٓ ۚ وَٱلْقَلَمِ وَمَا يَسْطُرُونَ",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5273,
          "text": "مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٍۢ",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5274,
          "text": "وَإِنَّ لَكَ لَأَجْرًا غَيْرَ مَمْنُونٍۢ",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5275,
          "text": "وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٍۢ",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5276,
          "text": "فَسَتُبْصِرُ وَيُبْصِرُونَ",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5277,
          "text": "بِأَييِّكُمُ ٱلْمَفْتُونُ",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5278,
          "text": "إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِٱلْمُهْتَدِينَ",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5279,
          "text": "فَلَا تُطِعِ ٱلْمُكَذِّبِينَ",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5280,
          "text": "وَدُّوا۟ لَوْ تُدْهِنُ فَيُدْهِنُونَ",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5281,
          "text": "وَلَا تُطِعْ كُلَّ حَلَّافٍۢ مَّهِينٍ",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5282,
          "text": "هَمَّازٍۢ مَّشَّآءٍۭ بِنَمِيمٍۢ",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5283,
          "text": "مَّنَّاعٍۢ لِّلْخَيْرِ مُعْتَدٍ أَثِيمٍ",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5284,
          "text": "عُتُلٍّۭ بَعْدَ ذَٰلِكَ زَنِيمٍ",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5285,
          "text": "أَن كَانَ ذَا مَالٍۢ وَبَنِينَ",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5286,
          "text": "إِذَا تُتْلَىٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلْأَوَّلِينَ",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5287,
          "text": "سَنَسِمُهُۥ عَلَى ٱلْخُرْطُومِ",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5288,
          "text": "إِنَّا بَلَوْنَٰهُمْ كَمَا بَلَوْنَآ أَصْحَٰبَ ٱلْجَنَّةِ إِذْ أَقْسَمُوا۟ لَيَصْرِمُنَّهَا مُصْبِحِينَ",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5289,
          "text": "وَلَا يَسْتَثْنُونَ",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5290,
          "text": "فَطَافَ عَلَيْهَا طَآئِفٌۭ مِّن رَّبِّكَ وَهُمْ نَآئِمُونَ",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5291,
          "text": "فَأَصْبَحَتْ كَٱلصَّرِيمِ",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5292,
          "text": "فَتَنَادَوْا۟ مُصْبِحِينَ",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5293,
          "text": "أَنِ ٱغْدُوا۟ عَلَىٰ حَرْثِكُمْ إِن كُنتُمْ صَٰرِمِينَ",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5294,
          "text": "فَٱنطَلَقُوا۟ وَهُمْ يَتَخَٰفَتُونَ",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5295,
          "text": "أَن لَّا يَدْخُلَنَّهَا ٱلْيَوْمَ عَلَيْكُم مِّسْكِينٌۭ",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5296,
          "text": "وَغَدَوْا۟ عَلَىٰ حَرْدٍۢ قَٰدِرِينَ",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5297,
          "text": "فَلَمَّا رَأَوْهَا قَالُوٓا۟ إِنَّا لَضَآلُّونَ",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5298,
          "text": "بَلْ نَحْنُ مَحْرُومُونَ",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5299,
          "text": "قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّحُونَ",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5300,
          "text": "قَالُوا۟ سُبْحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَ",
          "numberInSurah": 29,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5301,
          "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍۢ يَتَلَٰوَمُونَ",
          "numberInSurah": 30,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5302,
          "text": "قَالُوا۟ يَٰوَيْلَنَآ إِنَّا كُنَّا طَٰغِينَ",
          "numberInSurah": 31,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5303,
          "text": "عَسَىٰ رَبُّنَآ أَن يُبْدِلَنَا خَيْرًۭا مِّنْهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ",
          "numberInSurah": 32,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5304,
          "text": "كَذَٰلِكَ ٱلْعَذَابُ ۖ وَلَعَذَابُ ٱلْءَاخِرَةِ أَكْبَرُ ۚ لَوْ كَانُوا۟ يَعْلَمُونَ",
          "numberInSurah": 33,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5305,
          "text": "إِنَّ لِلْمُتَّقِينَ عِندَ رَبِّهِمْ جَنَّٰتِ ٱلنَّعِيمِ",
          "numberInSurah": 34,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5306,
          "text": "أَفَنَجْعَلُ ٱلْمُسْلِمِينَ كَٱلْمُجْرِمِينَ",
          "numberInSurah": 35,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5307,
          "text": "مَا لَكُمْ كَيْفَ تَحْكُمُونَ",
          "numberInSurah": 36,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5308,
          "text": "أَمْ لَكُمْ كِتَٰبٌۭ فِيهِ تَدْرُسُونَ",
          "numberInSurah": 37,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5309,
          "text": "إِنَّ لَكُمْ فِيهِ لَمَا تَخَيَّرُونَ",
          "numberInSurah": 38,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5310,
          "text": "أَمْ لَكُمْ أَيْمَٰنٌ عَلَيْنَا بَٰلِغَةٌ إِلَىٰ يَوْمِ ٱلْقِيَٰمَةِ ۙ إِنَّ لَكُمْ لَمَا تَحْكُمُونَ",
          "numberInSurah": 39,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5311,
          "text": "سَلْهُمْ أَيُّهُم بِذَٰلِكَ زَعِيمٌ",
          "numberInSurah": 40,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5312,
          "text": "أَمْ لَهُمْ شُرَكَآءُ فَلْيَأْتُوا۟ بِشُرَكَآئِهِمْ إِن كَانُوا۟ صَٰدِقِينَ",
          "numberInSurah": 41,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5313,
          "text": "يَوْمَ يُكْشَفُ عَن سَاقٍۢ وَيُدْعَوْنَ إِلَى ٱلسُّجُودِ فَلَا يَسْتَطِيعُونَ",
          "numberInSurah": 42,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5314,
          "text": "خَٰشِعَةً أَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٌۭ ۖ وَقَدْ كَانُوا۟ يُدْعَوْنَ إِلَى ٱلسُّجُودِ وَهُمْ سَٰلِمُونَ",
          "numberInSurah": 43,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5315,
          "text": "فَذَرْنِى وَمَن يُكَذِّبُ بِهَٰذَا ٱلْحَدِيثِ ۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ",
          "numberInSurah": 44,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5316,
          "text": "وَأُمْلِى لَهُمْ ۚ إِنَّ كَيْدِى مَتِينٌ",
          "numberInSurah": 45,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5317,
          "text": "أَمْ تَسْـَٔلُهُمْ أَجْرًۭا فَهُم مِّن مَّغْرَمٍۢ مُّثْقَلُونَ",
          "numberInSurah": 46,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5318,
          "text": "أَمْ عِندَهُمُ ٱلْغَيْبُ فَهُمْ يَكْتُبُونَ",
          "numberInSurah": 47,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5319,
          "text": "فَٱصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَاحِبِ ٱلْحُوتِ إِذْ نَادَىٰ وَهُوَ مَكْظُومٌۭ",
          "numberInSurah": 48,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5320,
          "text": "لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٌۭ مِّن رَّبِّهِۦ لَنُبِذَ بِٱلْعَرَآءِ وَهُوَ مَذْمُومٌۭ",
          "numberInSurah": 49,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5321,
          "text": "فَٱجْتَبَٰهُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ ٱلصَّٰلِحِينَ",
          "numberInSurah": 50,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5322,
          "text": "وَإِن يَكَادُ ٱلَّذِينَ كَفَرُوا۟ لَيُزْلِقُونَكَ بِأَبْصَٰرِهِمْ لَمَّا سَمِعُوا۟ ٱلذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٌۭ",
          "numberInSurah": 51,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5323,
          "text": "وَمَا هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ",
          "numberInSurah": 52,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 68,
      "name": "سُورَةُ القَلَمِ",
      "englishName": "Al-Qalam",
      "englishNameTranslation": "The Pen",
      "revelationType": "Meccan",
      "numberOfAyahs": 52,
      "ayahs": [
        {
          "number": 5272,
          "text": "নূন। শপথ কলমের এবং সেই বিষয়ের যা তারা লিপিবদ্ধ করে,",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5273,
          "text": "আপনার পালনকর্তার অনুগ্রহে আপনি উম্মাদ নন।",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5274,
          "text": "আপনার জন্যে অবশ্যই রয়েছে অশেষ পুরস্কার।",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5275,
          "text": "আপনি অবশ্যই মহান চরিত্রের অধিকারী।",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5276,
          "text": "সত্ত্বরই আপনি দেখে নিবেন এবং তারাও দেখে নিবে।",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5277,
          "text": "কে তোমাদের মধ্যে বিকারগ্রস্ত।",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5278,
          "text": "আপনার পালনকর্তা সম্যক জানেন কে তাঁর পথ থেকে বিচ্যুত হয়েছে এবং তিনি জানেন যারা সৎপথ প্রাপ্ত।",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5279,
          "text": "অতএব, আপনি মিথ্যারোপকারীদের আনুগত্য করবেন না।",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5280,
          "text": "তারা চায় যদি আপনি নমনীয় হন, তবে তারাও নমনীয় হবে।",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5281,
          "text": "যে অধিক শপথ করে, যে লাঞ্ছিত, আপনি তার আনুগত্য করবেন না।",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5282,
          "text": "যে পশ্চাতে নিন্দা করে একের কথা অপরের নিকট লাগিয়ে ফিরে।",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5283,
          "text": "যে ভাল কাজে বাধা দেয়, সে সীমালংঘন করে, সে পাপিষ্ঠ,",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5284,
          "text": "কঠোর স্বভাব, তদুপরি কুখ্যাত;",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5285,
          "text": "এ কারণে যে, সে ধন-সম্পদ ও সন্তান সন্ততির অধিকারী।",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5286,
          "text": "তার কাছে আমার আয়াত পাঠ করা হলে সে বলে; সেকালের উপকথা।",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 564,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5287,
          "text": "আমি তার নাসিকা দাগিয়ে দিব।",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5288,
          "text": "আমি তাদেরকে পরীক্ষা করেছি, যেমন পরীক্ষা করেছি উদ্যানওয়ালাদের, যখন তারা শপথ করেছিল যে, সকালে বাগানের ফল আহরণ করবে,",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5289,
          "text": "ইনশাআল্লাহ না বলে।",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5290,
          "text": "অতঃপর আপনার পালনকর্তার পক্ষ থেকে বাগানে এক বিপদ এসে পতিত হলো। যখন তারা নিদ্রিত ছিল।",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5291,
          "text": "ফলে সকাল পর্যন্ত হয়ে গেল ছিন্নবিচ্ছিন্ন তৃণসম।",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5292,
          "text": "সকালে তারা একে অপরকে ডেকে বলল,",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5293,
          "text": "তোমরা যদি ফল আহরণ করতে চাও, তবে সকাল সকাল ক্ষেতে চল।",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5294,
          "text": "অতঃপর তারা চলল ফিসফিস করে কথা বলতে বলতে,",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5295,
          "text": "অদ্য যেন কোন মিসকীন ব্যক্তি তোমাদের কাছে বাগানে প্রবেশ করতে না পারে।",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5296,
          "text": "তারা সকালে লাফিয়ে লাফিয়ে সজোরে রওয়ানা হল।",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5297,
          "text": "অতঃপর যখন তারা বাগান দেখল, তখন বললঃ আমরা তো পথ ভূলে গেছি।",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5298,
          "text": "বরং আমরা তো কপালপোড়া,",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5299,
          "text": "তাদের উত্তম ব্যক্তি বললঃ আমি কি তোমাদেরকে বলিনি? এখনও তোমরা আল্লাহ তা’আলার পবিত্রতা বর্ণনা করছো না কেন?",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5300,
          "text": "তারা বললঃ আমরা আমাদের পালনকর্তার পবিত্রতা ঘোষণা করছি, নিশ্চিতই আমরা সীমালংঘনকারী ছিলাম।",
          "numberInSurah": 29,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5301,
          "text": "অতঃপর তারা একে অপরকে ভৎর্সনা করতে লাগল।",
          "numberInSurah": 30,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5302,
          "text": "তারা বললঃ হায়! দুর্ভোগ আমাদের আমরা ছিলাম সীমাতিক্রমকারী।",
          "numberInSurah": 31,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5303,
          "text": "সম্ভবতঃ আমাদের পালনকর্তা পরিবর্তে এর চাইতে উত্তম বাগান আমাদেরকে দিবেন। আমরা আমাদের পালনকর্তার কাছে আশাবাদী।",
          "numberInSurah": 32,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5304,
          "text": "শাস্তি এভাবেই আসে এবং পরকালের শাস্তি আরও গুরুতর; যদি তারা জানত!",
          "numberInSurah": 33,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 498,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5305,
          "text": "মোত্তাকীদের জন্যে তাদের পালনকর্তার কাছে রয়েছে নেয়ামতের জান্নাত।",
          "numberInSurah": 34,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5306,
          "text": "আমি কি আজ্ঞাবহদেরকে অপরাধীদের ন্যায় গণ্য করব?",
          "numberInSurah": 35,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5307,
          "text": "তোমাদের কি হল ? তোমরা কেমন সিদ্ধান্ত দিচ্ছ?",
          "numberInSurah": 36,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5308,
          "text": "তোমাদের কি কোন কিতাব আছে, যা তোমরা পাঠ কর।",
          "numberInSurah": 37,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5309,
          "text": "তাতে তোমরা যা পছন্দ কর, তাই পাও?",
          "numberInSurah": 38,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5310,
          "text": "না তোমরা আমার কাছ থেকেকেয়ামত পর্যন্ত বলবৎ কোন শপথ নিয়েছ যে, তোমরা তাই পাবে যা তোমরা সিদ্ধান্ত করবে?",
          "numberInSurah": 39,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5311,
          "text": "আপনি তাদেরকে জিজ্ঞাসা করুন তাদের কে এ বিষয়ে দায়িত্বশীল?",
          "numberInSurah": 40,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5312,
          "text": "না তাদের কোন শরীক উপাস্য আছে? থাকলে তাদের শরীক উপাস্যদেরকে উপস্থিত করুক যদি তারা সত্যবাদী হয়।",
          "numberInSurah": 41,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5313,
          "text": "গোছা পর্যন্ত পা খোলার দিনের কথা স্মরণ কর, সেদিন তাদেরকে সেজদা করতে আহবান জানানো হবে, অতঃপর তারা সক্ষম হবে না।",
          "numberInSurah": 42,
          "juz": 29,
          "manzil": 7,
          "page": 565,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5314,
          "text": "তাদের দৃষ্টি অবনত থাকবে; তারা লাঞ্ছনাগ্রস্ত হবে, অথচ যখন তারা সুস্থ ও স্বাভাবিক অবস্থায় ছিল, তখন তাদেরকে সেজদা করতে আহবান জানানো হত।",
          "numberInSurah": 43,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5315,
          "text": "অতএব, যারা এই কালামকে মিথ্যা বলে, তাদেরকে আমার হাতে ছেড়ে দিন, আমি এমন ধীরে ধীরে তাদেরকে জাহান্নামের দিকে নিয়ে যাব যে, তারা জানতে পারবে না।",
          "numberInSurah": 44,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5316,
          "text": "আমি তাদেরকে সময় দেই। নিশ্চয় আমার কৌশল মজবুত।",
          "numberInSurah": 45,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5317,
          "text": "আপনি কি তাদের কাছে পারিশ্রমিক চান? ফলে তাদের উপর জরিমানার বোঝা পড়ছে?",
          "numberInSurah": 46,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5318,
          "text": "না তাদের কাছে গায়বের খবর আছে? অতঃপর তারা তা লিপিবদ্ধ করে।",
          "numberInSurah": 47,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5319,
          "text": "আপনি আপনার পালনকর্তার আদেশের অপেক্ষায় সবর করুন এবং মাছওয়ালা ইউনুসের মত হবেন না, যখন সে দুঃখাকুল মনে প্রার্থনা করেছিল।",
          "numberInSurah": 48,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5320,
          "text": "যদি তার পালনকর্তার অনুগ্রহ তাকে সামাল না দিত, তবে সে নিন্দিত অবস্থায় জনশুন্য প্রান্তরে নিক্ষিপ্ত হত।",
          "numberInSurah": 49,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5321,
          "text": "অতঃপর তার পালনকর্তা তাকে মনোনীত করলেন এবং তাকে সৎকর্মীদের অন্তর্ভুক্ত করে নিলেন।",
          "numberInSurah": 50,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5322,
          "text": "কাফেররা যখন কোরআন শুনে, তখন তারা তাদের দৃষ্টি দ্বারা যেন আপনাকে আছাড় দিয়ে ফেলে দিবে এবং তারা বলেঃ সে তো একজন পাগল।",
          "numberInSurah": 51,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        },
        {
          "number": 5323,
          "text": "অথচ এই কোরআন তো বিশ্বজগতের জন্যে উপদেশ বৈ নয়।",
          "numberInSurah": 52,
          "juz": 29,
          "manzil": 7,
          "page": 566,
          "ruku": 499,
          "hizbQuarter": 226,
          "sajda": false
        }
