  "data": [
    {
      "number": 88,
      "name": "سُورَةُ الغَاشِيَةِ",
      "englishName": "Al-Ghaashiya",
      "englishNameTranslation": "The Overwhelming",
      "revelationType": "Meccan",
      "numberOfAyahs": 26,
      "ayahs": [
        {
          "number": 5968,
          "text": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5969,
          "text": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5970,
          "text": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5971,
          "text": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5972,
          "text": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5973,
          "text": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5974,
          "text": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5975,
          "text": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5976,
          "text": "لِّسَعْيِهَا رَاضِيَةٌۭ",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5977,
          "text": "فِى جَنَّةٍ عَالِيَةٍۢ",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5978,
          "text": "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5979,
          "text": "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5980,
          "text": "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5981,
          "text": "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5982,
          "text": "وَنَمَارِقُ مَصْفُوفَةٌۭ",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5983,
          "text": "وَزَرَابِىُّ مَبْثُوثَةٌ",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5984,
          "text": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5985,
          "text": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5986,
          "text": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5987,
          "text": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5988,
          "text": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5989,
          "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5990,
          "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5991,
          "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5992,
          "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5993,
          "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "quran-uthmani",
        "language": "ar",
        "name": "القرآن الكريم برسم العثماني (uthmani)",
        "englishName": "Uthmani",
        "format": "text",
        "type": "quran",
        "direction": "rtl"
      }
    },
    {
      "number": 88,
      "name": "سُورَةُ الغَاشِيَةِ",
      "englishName": "Al-Ghaashiya",
      "englishNameTranslation": "The Overwhelming",
      "revelationType": "Meccan",
      "numberOfAyahs": 26,
      "ayahs": [
        {
          "number": 5968,
          "text": "আপনার কাছে আচ্ছন্নকারী কেয়ামতের বৃত্তান্ত পৌঁছেছে কি?",
          "numberInSurah": 1,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5969,
          "text": "অনেক মুখমন্ডল সেদিন হবে লাঞ্ছিত,",
          "numberInSurah": 2,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5970,
          "text": "ক্লিষ্ট, ক্লান্ত।",
          "numberInSurah": 3,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5971,
          "text": "তারা জ্বলন্ত আগুনে পতিত হবে।",
          "numberInSurah": 4,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5972,
          "text": "তাদেরকে ফুটন্ত নহর থেকে পান করানো হবে।",
          "numberInSurah": 5,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5973,
          "text": "কন্টকপূর্ণ ঝাড় ব্যতীত তাদের জন্যে কোন খাদ্য নেই।",
          "numberInSurah": 6,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5974,
          "text": "এটা তাদেরকে পুষ্ট করবে না এবং ক্ষুধায়ও উপকার করবে না।",
          "numberInSurah": 7,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5975,
          "text": "অনেক মুখমন্ডল সেদিন হবে, সজীব,",
          "numberInSurah": 8,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5976,
          "text": "তাদের কর্মের কারণে সন্তুষ্ট।",
          "numberInSurah": 9,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5977,
          "text": "তারা থাকবে, সুউচ্চ জান্নাতে।",
          "numberInSurah": 10,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5978,
          "text": "তথায় শুনবে না কোন অসার কথাবার্তা।",
          "numberInSurah": 11,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5979,
          "text": "তথায় থাকবে প্রবাহিত ঝরণা।",
          "numberInSurah": 12,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5980,
          "text": "তথায় থাকবে উন্নত সুসজ্জিত আসন।",
          "numberInSurah": 13,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5981,
          "text": "এবং সংরক্ষিত পানপাত্র",
          "numberInSurah": 14,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5982,
          "text": "এবং সারি সারি গালিচা",
          "numberInSurah": 15,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5983,
          "text": "এবং বিস্তৃত বিছানো কার্পেট।",
          "numberInSurah": 16,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5984,
          "text": "তারা কি উষ্ট্রের প্রতি লক্ষ্য করে না যে, তা কিভাবে সৃষ্টি করা হয়েছে?",
          "numberInSurah": 17,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5985,
          "text": "এবং আকাশের প্রতি লক্ষ্য করে না যে, তা কিভাবে উচ্চ করা হয়েছে?",
          "numberInSurah": 18,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5986,
          "text": "এবং পাহাড়ের দিকে যে, তা কিভাবে স্থাপন করা হয়েছে?",
          "numberInSurah": 19,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5987,
          "text": "এবং পৃথিবীর দিকে যে, তা কিভাবে সমতল বিছানো হয়েছে?",
          "numberInSurah": 20,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5988,
          "text": "অতএব, আপনি উপদেশ দিন, আপনি তো কেবল একজন উপদেশদাতা,",
          "numberInSurah": 21,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5989,
          "text": "আপনি তাদের শাসক নন,",
          "numberInSurah": 22,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5990,
          "text": "কিন্তু যে মুখ ফিরিয়ে নেয় ও কাফের হয়ে যায়,",
          "numberInSurah": 23,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5991,
          "text": "আল্লাহ তাকে মহা আযাব দেবেন।",
          "numberInSurah": 24,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5992,
          "text": "নিশ্চয় তাদের প্রত্যাবর্তন আমারই নিকট,",
          "numberInSurah": 25,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        },
        {
          "number": 5993,
          "text": "অতঃপর তাদের হিসাব-নিকাশ আমারই দায়িত্ব।",
          "numberInSurah": 26,
          "juz": 30,
          "manzil": 7,
          "page": 592,
          "ruku": 530,
          "hizbQuarter": 237,
          "sajda": false
        }
      ],
      "edition": {
        "identifier": "bn.bengali",
