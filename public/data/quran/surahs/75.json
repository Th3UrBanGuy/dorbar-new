      }
    },
    {
      "number": 75,
      "name": "سُورَةُ القِيَامَةِ",
      "englishName": "Al-Qiyaama",
      "englishNameTranslation": "The Resurrection",
      "revelationType": "Meccan",
      "numberOfAyahs": 40,
      "ayahs": [
        {
          "number": 5552,
          "text": "আমি শপথ করি কেয়ামত দিবসের,",
          "numberInSurah": 1,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5553,
          "text": "আরও শপথ করি সেই মনের, যে নিজেকে ধিক্কার দেয়-",
          "numberInSurah": 2,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5554,
          "text": "মানুষ কি মনে করে যে আমি তার অস্থিসমূহ একত্রিত করব না?",
          "numberInSurah": 3,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5555,
          "text": "পরন্ত আমি তার অংগুলিগুলো পর্যন্ত সঠিকভাবে সন্নিবেশিত করতে সক্ষম।",
          "numberInSurah": 4,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5556,
          "text": "বরং মানুষ তার ভবিষ্যত জীবনেও ধৃষ্টতা করতে চায়",
          "numberInSurah": 5,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5557,
          "text": "সে প্রশ্ন করে-কেয়ামত দিবস কবে?",
          "numberInSurah": 6,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5558,
          "text": "যখন দৃষ্টি চমকে যাবে,",
          "numberInSurah": 7,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5559,
          "text": "চন্দ্র জ্যোতিহীন হয়ে যাবে।",
          "numberInSurah": 8,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5560,
          "text": "এবং সূর্য ও চন্দ্রকে একত্রিত করা হবে-",
          "numberInSurah": 9,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5561,
          "text": "সে দিন মানুষ বলবেঃ পলায়নের জায়গা কোথায় ?",
          "numberInSurah": 10,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5562,
          "text": "না কোথাও আশ্রয়স্থল নেই।",
          "numberInSurah": 11,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5563,
          "text": "আপনার পালনকর্তার কাছেই সেদিন ঠাঁই হবে।",
          "numberInSurah": 12,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5564,
          "text": "সেদিন মানুষকে অবহিত করা হবে সে যা সামনে প্রেরণ করেছে ও পশ্চাতে ছেড়ে দিয়েছে।",
          "numberInSurah": 13,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5565,
          "text": "বরং মানুষ নিজেই তার নিজের সম্পর্কে চক্ষুমান।",
          "numberInSurah": 14,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5566,
          "text": "যদিও সে তার অজুহাত পেশ করতে চাইবে।",
          "numberInSurah": 15,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5567,
          "text": "তাড়াতাড়ি শিখে নেয়ার জন্যে আপনি দ্রুত ওহী আবৃত্তি করবেন না।",
          "numberInSurah": 16,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5568,
          "text": "এর সংরক্ষণ ও পাঠ আমারই দায়িত্ব।",
          "numberInSurah": 17,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5569,
          "text": "অতঃপর আমি যখন তা পাঠ করি, তখন আপনি সেই পাঠের অনুসরণ করুন।",
          "numberInSurah": 18,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5570,
          "text": "এরপর বিশদ বর্ণনা আমারই দায়িত্ব।",
          "numberInSurah": 19,
          "juz": 29,
          "manzil": 7,
          "page": 577,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5571,
          "text": "কখনও না, বরং তোমরা পার্থিব জীবনকে ভালবাস",
          "numberInSurah": 20,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5572,
          "text": "এবং পরকালকে উপেক্ষা কর।",
          "numberInSurah": 21,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5573,
          "text": "সেদিন অনেক মুখমন্ডল উজ্জ্বল হবে।",
          "numberInSurah": 22,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5574,
          "text": "তারা তার পালনকর্তার দিকে তাকিয়ে থাকবে।",
          "numberInSurah": 23,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5575,
          "text": "আর অনেক মুখমন্ডল সেদিন উদাস হয়ে পড়বে।",
          "numberInSurah": 24,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5576,
          "text": "তারা ধারণা করবে যে, তাদের সাথে কোমর-ভাঙ্গা আচরণ করা হবে।",
          "numberInSurah": 25,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5577,
          "text": "কখনও না, যখন প্রাণ কন্ঠাগত হবে।",
          "numberInSurah": 26,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5578,
          "text": "এবং বলা হবে, কে ঝাড়বে",
          "numberInSurah": 27,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5579,
          "text": "এবং সে মনে করবে যে, বিদায়ের ক্ষণ এসে গেছে।",
          "numberInSurah": 28,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5580,
          "text": "এবং গোছা গোছার সাথে জড়িত হয়ে যাবে।",
          "numberInSurah": 29,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5581,
          "text": "সেদিন, আপনার পালনকর্তার নিকট সবকিছু নীত হবে।",
          "numberInSurah": 30,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 512,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5582,
          "text": "সে বিশ্বাস করেনি এবং নামায পড়েনি;",
          "numberInSurah": 31,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5583,
          "text": "পরন্ত মিথ্যারোপ করেছে ও পৃষ্ঠ প্রদর্শন করেছে।",
          "numberInSurah": 32,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5584,
          "text": "অতঃপর সে দম্ভভরে পরিবার-পরিজনের নিকট ফিরে গিয়েছে।",
          "numberInSurah": 33,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5585,
          "text": "তোমার দুর্ভোগের উপর দুর্ভোগ।",
          "numberInSurah": 34,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5586,
          "text": "অতঃপর, তোমার দুর্ভোগের উপর দূর্ভোগ।",
          "numberInSurah": 35,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5587,
          "text": "মানুষ কি মনে করে যে, তাকে এমনি ছেড়ে দেয়া হবে?",
          "numberInSurah": 36,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5588,
          "text": "সে কি স্খলিত বীর্য ছিল না?",
          "numberInSurah": 37,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5589,
          "text": "অতঃপর সে ছিল রক্তপিন্ড, অতঃপর আল্লাহ তাকে সৃষ্টি করেছেন এবং সুবিন্যস্ত করেছেন।",
          "numberInSurah": 38,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5590,
          "text": "অতঃপর তা থেকে সৃষ্টি করেছেন যুগল নর ও নারী।",
          "numberInSurah": 39,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        },
        {
          "number": 5591,
          "text": "তবুও কি সেই আল্লাহ মৃতদেরকে জীবিত করতে সক্ষম নন?",
          "numberInSurah": 40,
          "juz": 29,
          "manzil": 7,
          "page": 578,
          "ruku": 513,
          "hizbQuarter": 231,
          "sajda": false
        }
      ],
